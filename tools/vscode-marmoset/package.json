{
  "name": "marmoset",
  "displayName": "Marmoset",
  "description": "Marmoset language support",
  "version": "0.2.0",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "languages": [
      {
        "id": "marmoset",
        "aliases": [
          "Marmoset"
        ],
        "extensions": [
          ".mr"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "marmoset",
        "scopeName": "source.marmoset",
        "path": "./syntaxes/marmoset.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Marmoset",
      "properties": {
        "marmoset.lsp.path": {
          "type": "string",
          "default": "marmoset-lsp",
          "description": "Path to the marmoset-lsp binary"
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  }
}
