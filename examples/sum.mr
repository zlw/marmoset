let reduce = fn(values, initial, step) {
  let iter = fn(remaining, acc) {
    if (len(remaining) == 0) {
      acc
    } else {
      iter(rest(remaining), step(acc, first(remaining)))
    }
  }
  iter(values, initial)
}

let sum = fn(values) {
  reduce(values, 0, fn(acc, value) { acc + value })
}

puts(sum([1,2,3,4,5]))
