# CS21: C22: generic fn with generic enum at multiple types
enum Box[a] = { Wrap(a) }
fn unwrap(b: Box[Int]) -> Int = {
  match b { case Box.Wrap(v): v }
}
fn unwrap_str(b: Box[Str]) -> Str = {
  match b { case Box.Wrap(v): v }
}
puts(unwrap(Box.Wrap(42)))  # output: 42
puts(unwrap_str(Box.Wrap("hello")))  # output: hello
