# CS47: H48: [BUG-1] two enum matches in function body
enum option[a] { some(a) none }
let f = fn(a: option[int], b: option[int]) => int {
  let x = match a {
    option.some(v): v
    option.none: 0
  }
  let y = match b {
    option.some(v): v
    option.none: 0
  }
  puts(x)
  puts(y)
  x + y
}
# output: 42
# output: 99
f(option.some(42), option.some(99))
