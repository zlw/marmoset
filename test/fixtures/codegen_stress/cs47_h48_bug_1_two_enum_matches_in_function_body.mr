# CS47: H48: [BUG-1] two enum matches in function body
enum Option[a] = { Some(a), None }
fn f(a: Option[Int], b: Option[Int]) => Int = {
  let x = match a {
    case Option.Some(v): v
    case Option.None: 0
  }
  let y = match b {
    case Option.Some(v): v
    case Option.None: 0
  }
  puts(x)
  puts(y)
  x + y
}
# output: 42
# output: 99
f(Option.Some(42), Option.Some(99))
