# CS55: H56: triple-nested match in tail position
fn classify(a: Int, b: Int, c: Int) -> Int = {
  match a {
    case 1: match b {
      case 1: match c { case 1: 111 case _: 110 }
      case _: 100
    }
    case 3: match b {
      case 2: match c { case 1: 321 case _: 320 }
      case _: 300
    }
    case _: 0
  }
}
puts(classify(3, 2, 1))  # output: 321
