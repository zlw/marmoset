# CS48: H49: [BUG-1] three matches different types same scope
let a = 1
let b = "hello"
let c = true
let x = match a { case 1: 10 case _: 0 }
puts(x)  # output: 10
let y = match b { case "hello": "hello" case _: "other" }
puts(y)  # output: hello
let z = match c { case true: true case false: false }
puts(z)  # output: true
