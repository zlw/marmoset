# TH43: Inherent method on enum with non-keyword param (workaround)
enum OptionInt = {
  Some(Int),
  None,
}
impl OptionInt = {
  fn unwrap_or(o: OptionInt, fallback: Int) -> Int = {
    match o {
      case OptionInt.Some(v): v
      case OptionInt.None: fallback
    }
  }
}
let x = OptionInt.Some(1)
puts(OptionInt.unwrap_or(x, 0))  # output: 1
