# TH37: Generic inherent impl target on enum type works
enum Result[a, b] = {
  Success(a),
  Failure(b),
}
impl Result[a, b] = {
  fn is_success(r: Result[a, b]) -> Bool = {
    match r {
      case Result.Success(_): true
      case Result.Failure(_): false
    }
  }
}
let ok = if (true) { Result.Success(1) } else { Result.Failure("x") }
let err = if (false) { Result.Success(1) } else { Result.Failure("x") }
puts(ok.is_success())  # output: true
puts(err.is_success())  # output: false
