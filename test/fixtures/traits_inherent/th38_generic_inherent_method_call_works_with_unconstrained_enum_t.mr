# TH38: Generic inherent method call works with unconstrained enum type arguments
enum Result[a, b] = {
  Success(a),
  Failure(b),
}
impl Result[a, b] = {
  fn is_success(r: Result[a, b]) -> Bool = {
    match r {
      case Result.Success(_): true
      case Result.Failure(_): false
    }
  }
}
let ok = Result.Success(1)
puts(Result.is_success(ok))  # output: true
