# TH28: Two different types each with inherent methods
type Point = { x: Int, y: Int }
type Label = { text: Str }
impl Point = {
  fn sum(p: Point) -> Int = p.x + p.y
}
impl Label = {
  fn get_text(l: Label) -> Str = l.text
}
let p = {x: 10, y: 20}
let l = {text: "hello"}
puts(Point.sum(p))  # output: 30
puts(Label.get_text(l))  # output: hello
