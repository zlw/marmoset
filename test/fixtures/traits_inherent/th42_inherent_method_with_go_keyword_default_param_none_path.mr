# TH42: Inherent method with Go keyword 'default' param (none path)
enum OptionInt = {
  Some(Int),
  None,
}
impl OptionInt = {
  fn unwrap_or(o: OptionInt, default: Int) -> Int = {
    match o {
      case OptionInt.Some(v): v
      case OptionInt.None: default
    }
  }
}
let x = OptionInt.None
puts(x.unwrap_or(99))  # output: 99
