# TH42: Inherent method with Go keyword 'default' param (none path)
# output: 99
enum option_int { some(int) none }
impl option_int {
  fn unwrap_or(o: option_int, default: int) -> int {
    match o {
      option_int.some(v): v
      option_int.none: default
    }
  }
}
let x = option_int.none
puts(x.unwrap_or(99))
