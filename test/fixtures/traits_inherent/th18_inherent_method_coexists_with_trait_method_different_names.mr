# TH18: Inherent method coexists with trait method (different names)
type Point = { x: Int, y: Int }
trait Describable[a] = {
  fn describe(x: a) -> Str
}
impl Describable[Point] = {
  fn describe(p: Point) -> Str = "hello"
}
impl Point = {
  fn sum(p: Point) -> Int = p.x + p.y
}
let p: Point = { x: 20, y: 22 }
puts(p.describe())  # output: hello
puts(p.sum())  # output: 42
