# TH39: Concrete inherent impl target takes precedence over matching generic target
type Result[a, b] = {
  Success(a),
  Failure(b),
}
impl Result[a, b] = {
  fn tag(r: Result[a, b]) -> Str = {
    match r {
      case Result.Success(_): "success"
      case Result.Failure(_): "failure"
    }
  }
}
impl Result[Int, Str] = {
  fn tag(r: Result[Int, Str]) -> Str = "concrete"
}
let x = if (true) { Result.Success(1) } else { Result.Failure("boom") }
let y = if (false) { Result.Success(true) } else { Result.Failure("boom") }
puts(Result.tag(x))  # output: concrete
puts(Result.tag(y))  # output: failure
