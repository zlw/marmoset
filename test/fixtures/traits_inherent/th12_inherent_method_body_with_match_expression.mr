# TH12: Inherent method body with match expression
type Color = {
  Red,
  Green,
  Blue,
}
impl Color = {
  fn rank(c: Color) -> Str = {
    match c {
      case Color.Red: "one"
      case Color.Green: "two"
      case Color.Blue: "three"
    }
  }
}
let c = Color.Red
puts(Color.rank(c))  # output: one
