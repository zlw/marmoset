# TH20: Inherent method does NOT satisfy trait constraints
trait Showable[a] = {
  fn display(x: a) -> Str
}
type Widget = { id: Int }
impl Widget = {
  fn display(w: Widget) -> Str = "widget"
}
fn render[t: Showable](x: t) -> Str = {
  x.display()
}
let w = Widget(id: 1)
puts(render(w))  # error: does not implement trait
