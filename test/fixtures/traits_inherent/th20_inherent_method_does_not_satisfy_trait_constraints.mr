# TH20: Inherent method does NOT satisfy trait constraints
trait showable[a] {  # error: does not implement trait
  fn display(x: a) -> string
}
type widget = { id: int }
impl widget {
  fn display(w: widget) -> string { "widget" }
}
let render = fn[t: showable](x: t) -> string {
  x.display()
}
let w: widget = { id: 1 }
puts(render(w))
