# TH41: Inherent method with Go keyword 'default' as param name
enum OptionInt = {
  Some(Int),
  None,
}
impl OptionInt = {
  fn unwrap_or(o: OptionInt, default: Int) -> Int = {
    match o {
      case OptionInt.Some(v): v
      case OptionInt.None: default
    }
  }
}
let x = OptionInt.Some(1)
puts(x.unwrap_or(0))  # output: 1
