# CG14: Canonical names keep the old collision shapes distinct
type B = { V }
type A[t] = { Wrap(t) }
type AB = { Wrap }
fn id(x) = x
let x = id(AB.Wrap)
let y = id(A.Wrap(B.V))
let x_label = match x {
  case AB.Wrap: "ab"
}
let y_label = match y {
  case A.Wrap(_): "aofb"
}
puts(x_label)  # output: ab
puts(y_label)  # output: aofb
