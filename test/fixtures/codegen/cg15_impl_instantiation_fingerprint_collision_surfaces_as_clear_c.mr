# CG15: Impl instantiation fingerprint collision surfaces as clear codegen error
enum b { v }  # error: Codegen error: impl instantiation fingerprint collision for 'show.show'
enum a[t] { wrap(t) }
enum a_b { wrap }
trait show[x] { fn show(x: x) -> string }
impl show for a_b {
  fn show(x: a_b) -> string { "AB" }
}
impl show for a[b] {
  fn show(x: a[b]) -> string { "AofB" }
}
puts(1)
