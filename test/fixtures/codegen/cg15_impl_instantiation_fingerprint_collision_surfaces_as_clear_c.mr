# CG15: Canonical names keep the old impl collision shapes distinct
enum B = { V }
enum A[t] = { Wrap(t) }
enum AB = { Wrap }
trait Show[x] = { fn show(x: x) -> Str }
impl Show[AB] = {
  fn show(x: AB) -> Str = "AB"
}
impl Show[A[B]] = {
  fn show(x: A[B]) -> Str = "AofB"
}
puts(AB.Wrap.show())  # output: AB
puts(A.Wrap(B.V).show())  # output: AofB
