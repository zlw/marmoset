# CG15: Canonical names keep the old impl collision shapes distinct
type B = { V }
type A[t] = { Wrap(t) }
type AB = { Wrap }
trait Show[x] = { fn show(x: x) -> Str }
impl Show[AB] = {
  fn show(x: AB) -> Str = "AB"
}
impl Show[A[B]] = {
  fn show(x: A[B]) -> Str = "AofB"
}
puts(Show.show(AB.Wrap))  # output: AB
puts(Show.show(A.Wrap(B.V)))  # output: AofB
