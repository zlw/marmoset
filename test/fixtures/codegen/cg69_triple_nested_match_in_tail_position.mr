# CG69: Triple-nested match in tail position
fn f(x: Int, y: Int, z: Int) -> Int = {
  match x {
    case 1: match y {
      case 1: match z {
        case 1: 111
        case _: 110
      }
      case _: 100
    }
    case 3: match y {
      case 2: match z {
        case 1: 321
        case _: 320
      }
      case _: 300
    }
    case _: 0
  }
}
puts(f(3, 2, 1))  # output: 321
