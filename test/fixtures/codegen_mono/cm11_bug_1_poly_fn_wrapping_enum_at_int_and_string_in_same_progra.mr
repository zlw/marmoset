# CM11: [BUG-1] Poly fn wrapping enum at Int AND Str in same program
enum Option[a] = { Some(a), None }
fn wrap(x) = Option.Some(x)
let v1 = wrap(42)
let v2 = wrap("hello")
match v1 {  # output: 42
  case Option.Some(n): puts(n)
  case Option.None: puts(0)
}
match v2 {  # output: hello
  case Option.Some(s): puts(s)
  case Option.None: puts("none")
}
