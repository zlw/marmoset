# CM23: Fn with enum match uses fallback param
enum Option[a] = { Some(a), None }
fn unwrap_or(opt: Option[Int], fallback: Int) -> Int = {
  match opt {
    case Option.Some(v): v
    case Option.None: fallback
  }
}
puts(unwrap_or(Option.Some(42), 0))  # output: 42
puts(unwrap_or(Option.None(), 0))  # output: 0
