# CM44: Dyn with builtin and custom method traits dispatches both methods
trait Render[a] = {
  fn render(x: a) -> Str
}
impl Render[Int] = {
  fn render(x: Int) -> Str = "render:" + Show.show(x)
}
let x: Dyn[Show & Render] = 42
puts(Show.show(x))  # output: 42
puts(Render.render(x))  # output: render:42
