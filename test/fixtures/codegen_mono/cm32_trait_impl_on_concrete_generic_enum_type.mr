# CM32: Trait impl on concrete generic enum type
enum Option[a] = { Some(a), None }
trait Describe[a] = {
  fn describe(x: a) -> Str
}
impl Describe[Option[Int]] = {
  fn describe(x: Option[Int]) -> Str = {
    match x {
      case Option.Some(_): "present"
      case Option.None: "absent"
    }
  }
}
let v: Option[Int] = Option.Some(42)
puts(Describe.describe(v))  # output: present
