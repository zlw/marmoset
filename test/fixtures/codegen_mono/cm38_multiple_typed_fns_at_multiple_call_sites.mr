# CM38: Multiple typed fns at multiple call sites
fn double_int(x: Int) -> Int = x * 2
fn half_float(x: Float) -> Float = x / 2.0
fn negate_bool(x: Bool) -> Bool = if (x) { false } else { true }
fn upper_str(x: Str) -> Str = "HELLO"
fn add_ints(x: Int, y: Int) -> Int = x + y
puts(double_int(1))  # output: 2
puts(half_float(1.0))  # output: 0.5
puts(negate_bool(true))  # output: false
puts(upper_str("hello"))  # output: HELLO
puts(add_ints(1, 2))  # output: 3
puts(add_ints(3, 4))  # output: 7
