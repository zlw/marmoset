# CM47: Dyn trait objects support method dispatch when a method-only trait depends on a shape
shape Named = { name: Str }
type Person = { name: Str }
trait NamedShow[a]: Named = {
  fn show(x: a) -> Str
}
impl NamedShow[Person] = {
  fn show(x: Person) -> Str = x.name
}
let x: Dyn[NamedShow] = {name: "alice"}
puts(NamedShow.show(x))  # output: alice
