# CM12: [BUG-1] Generic enum Box used at Int, Bool, Str
enum Box[a] = { Wrap(a) }
let a: Box[Int] = Box.Wrap(42)
let b: Box[Bool] = Box.Wrap(true)
let c: Box[Str] = Box.Wrap("hello")
match a { case Box.Wrap(v): puts(v) }  # output: 42
match b { case Box.Wrap(v): puts(v) }  # output: true
match c { case Box.Wrap(v): puts(v) }  # output: hello
