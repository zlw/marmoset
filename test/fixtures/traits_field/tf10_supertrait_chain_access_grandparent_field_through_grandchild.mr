# TF10: Supertrait chain: access grandparent field through grandchild constraint
trait LevelA = {
  a_field: Str
}
trait LevelB: LevelA = {
  b_field: Int
}
trait LevelC: LevelB = {
  c_field: Int
}
fn get_a[t: LevelC](v: t) -> Str = v.a_field
let r = { a_field: "deep", b_field: 1, c_field: 2 }
puts(get_a(r))  # output: deep
