# TF10: Nested shape fields remain available through the widest shape
shape LevelA = {
  a_field: Str
}
shape LevelB = {
  a_field: Str
  b_field: Int
}
shape LevelC = {
  a_field: Str
  b_field: Int
  c_field: Int
}
fn get_a[t: LevelC](v: t) -> Str = v.a_field
let r = { a_field: "deep", b_field: 1, c_field: 2 }
puts(get_a(r))  # output: deep
