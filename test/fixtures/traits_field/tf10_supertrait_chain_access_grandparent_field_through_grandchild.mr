# TF10: Supertrait chain: access grandparent field through grandchild constraint
# output: deep
trait level_a {
  a_field: string
}
trait level_b: level_a {
  b_field: int
}
trait level_c: level_b {
  c_field: int
}
let get_a = fn[t: level_c](v: t) -> string {
  v.a_field
};
let r = { a_field: "deep", b_field: 1, c_field: 2 }
puts(get_a(r))
