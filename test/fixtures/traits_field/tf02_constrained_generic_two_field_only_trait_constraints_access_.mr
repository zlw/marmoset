# TF02: Constrained generic: two field-only trait constraints, access each field
trait HasName = {
  name: Str
}
trait HasAge = {
  age: Int
}
fn describe[t: HasName & HasAge](v: t) -> Str = v.name
fn get_age[t: HasName & HasAge](v: t) -> Int = v.age
let p = { name: "hello", age: 42, active: true }
puts(describe(p))  # output: hello
puts(get_age(p))  # output: 42
