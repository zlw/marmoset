# TF02: Constrained generic: two field-only trait constraints, access each field
# output: hello
# output: 42
trait has_name {
  name: string
}
trait has_age {
  age: int
}
let describe = fn[t: has_name + has_age](v: t) -> string {
  v.name
};
let get_age = fn[t: has_name + has_age](v: t) -> int {
  v.age
};
let p = { name: "hello", age: 42, active: true }
puts(describe(p))
puts(get_age(p))
