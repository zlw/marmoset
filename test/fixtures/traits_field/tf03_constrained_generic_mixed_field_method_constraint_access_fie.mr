# TF03: Constrained generic: mixed field+method constraint, access field
# output: alice
type person = { name: string, age: int }
trait named {
  name: string
}
trait shown[a] {
  fn show(x: a) -> string
}
impl shown for person {
  fn show(x: person) -> string {
    x.name
  }
}
let get_name = fn[t: named + shown](v: t) -> string {
  v.name
};
let p: person = { name: "alice", age: 30 }
puts(get_name(p))
