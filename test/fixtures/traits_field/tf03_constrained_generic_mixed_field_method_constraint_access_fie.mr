# TF03: Constrained generic: mixed field+method constraint, access field
type Person = { name: Str, age: Int }
trait Named = {
  name: Str
}
trait Shown[a] = {
  fn show(x: a) -> Str
}
impl Shown[Person] = {
  fn show(x: Person) -> Str = x.name
}
fn get_name[t: Named & Shown](v: t) -> Str = v.name
let p: Person = { name: "alice", age: 30 }
puts(get_name(p))  # output: alice
