# TF18: Constrained generic: access field and call method on same value
type Person = { name: Str, age: Int }
trait Named = {
  name: Str
}
trait Shown[a] = {
  fn show(x: a) -> Str
}
impl Shown[Person] = {
  fn show(x: Person) -> Str = "shown"
}
fn describe[t: Named & Shown](v: t) -> Str = v.name + ": " + v.show()
let p: Person = { name: "alice", age: 30 }
puts(describe(p))  # output: alice: shown
