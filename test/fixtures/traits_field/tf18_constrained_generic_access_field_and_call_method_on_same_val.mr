# TF18: Constrained generic: access shape field and call trait method on same value
type Person = { name: Str, age: Int }
shape Named = {
  name: Str
}
trait Shown[a] = {
  fn show(x: a) -> Str
}
impl Shown[Person] = {
  fn show(x: Person) -> Str = "shown"
}
fn describe[t: Named & Shown](v: t) -> Str = v.name + ": " + Show.show(v)
let p = {name: "alice", age: 30}
puts(describe(p))  # output: alice: shown
