# TF34: Constrained generic called with different records
# output: first
# output: second
trait has_label {
  label: string
}
let get_label = fn[t: has_label](v: t) -> string {
  v.label
};
let r1 = { label: "first", x: 1 }
let r2 = { label: "second", y: true }
puts(get_label(r1))
puts(get_label(r2))
