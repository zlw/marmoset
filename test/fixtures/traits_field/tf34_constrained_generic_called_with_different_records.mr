# TF34: Constrained generic called with different records satisfying one shape
shape HasLabel = {
  label: Str
}
fn get_label[t: HasLabel](v: t) -> Str = v.label
let r1 = { label: "first", x: 1 }
let r2 = { label: "second", y: true }
puts(get_label(r1))  # output: first
puts(get_label(r2))  # output: second
