type Widget = { v: Int }

trait Display[a] = {
  fn render(x: a) -> Str
}

impl Display[Widget] = {
  fn render(x: Widget) -> Str = { "trait" }
}

impl Widget = {
  fn render(w: Widget) -> Str = { "inherent" }
}

# Both definitions are accepted; explicit targets select the implementation
let w = {v: 1}

puts(Display.render(w))  # output: trait
puts(Widget.render(w))  # output: inherent
