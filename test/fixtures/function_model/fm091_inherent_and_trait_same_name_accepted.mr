type Widget = { v: Int }

trait Display[a] = {
  fn render(x: a) -> Str
}

impl Display[Widget] = {
  fn render(x: Widget) -> Str = { "trait" }
}

impl Widget = {
  fn render(w: Widget) -> Str = { "inherent" }
}

# Both definitions accepted; dot call picks inherent
let w = {v: 1}

puts(w.render())  # output: inherent
