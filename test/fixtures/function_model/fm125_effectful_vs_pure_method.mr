type Logger = { prefix: Str }

impl Logger = {
  fn format(l: Logger, msg: Str) -> Str = {
    l.prefix + ": " + msg
  }
  fn log(l: Logger, msg: Str) => Str = {
    l.prefix + ": " + msg
  }
}

let l = Logger(prefix: "INFO")

puts(l.format("hello"))  # output: INFO: hello
puts(l.log("world"))  # output: INFO: world
