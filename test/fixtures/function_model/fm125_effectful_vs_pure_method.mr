type Logger = { prefix: Str }

impl Logger = {
  fn format(l: Logger, msg: Str) -> Str = {
    l.prefix + ": " + msg
  }
  fn log(l: Logger, msg: Str) => Str = {
    l.prefix + ": " + msg
  }
}

let l = {prefix: "INFO"}

puts(Logger.format(l, "hello"))  # output: INFO: hello
puts(Logger.log(l, "world"))  # output: INFO: world
