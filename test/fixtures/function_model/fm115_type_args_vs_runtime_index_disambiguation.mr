# xfail: method call type args syntax not implemented
type box = { v: int }

impl box {
  fn cast[b](bx: box, f: fn(int) -> b) -> b {
    f(bx.v)
  }
}

let b: box = { v: 5 }
# method type args: .cast[string](...) → method call with type arg
let s = b.cast[string](fn(n: int) -> string { n.show() })
puts(s)  # output: 5
