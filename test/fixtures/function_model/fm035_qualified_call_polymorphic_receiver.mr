trait Stringify[a] = {
  fn to_str(x: a) -> Str
}

impl Stringify[Int] = {
  fn to_str(x: Int) -> Str = {
    x.show()
  }
}

impl Stringify[Bool] = {
  fn to_str(x: Bool) -> Str = {
    if (x) { "T" } else { "F" }
  }
}

puts(Stringify.to_str(42))  # output: 42
puts(Stringify.to_str(true))  # output: T
