trait stringify[a] {
  fn to_str(x: a) -> string
}

impl stringify for int {
  fn to_str(x: int) -> string {
    x.show()
  }
}

impl stringify for bool {
  fn to_str(x: bool) -> string {
    if (x) { "T" } else { "F" }
  }
}

puts(stringify.to_str(42))  # output: 42
puts(stringify.to_str(true))  # output: T
