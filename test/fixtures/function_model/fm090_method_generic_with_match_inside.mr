type Opt[a] = { Some(a), None }

impl[a] Opt[a] = {
  fn flat_map[b](o: Opt[a], f: (a) -> Opt[b]) -> Opt[b] = match o {
    case Opt.Some(v): f(v)
    case Opt.None: Opt.None
  }
}

let x: Opt[Int] = Opt.Some(5)
let y: Opt[Str] = Opt.flat_map(x, (n: Int) -> {
  if (n > 0) { Opt.Some(Show.show(n)) } else { Opt.None }
})
