# xfail: supertrait-expanded ambiguity not implemented
trait Base[a] = {
  fn name(x: a) -> Str
}

trait Ext[a]: Base = {
  fn extra(x: a) -> Int
}

type Thing = { v: Int }

impl Base[Thing] = {
  fn name(x: Thing) -> Str = { "base" }
}

impl Ext[Thing] = {
  fn extra(x: Thing) -> Int = { x.v }
  fn name(x: Thing) -> Str = { "ext" }
}

let t: Thing = { v: 1 }
# base.name and ext.name both provide `name` → ambiguity
t.name()  # error: Ambiguous
