type Node = { id: Int }

trait Visitor[a] = {
  fn visit(x: a) -> Str
}

trait Walker[a] = {
  fn visit(x: a) -> Str
}

impl Visitor[Node] = {
  fn visit(x: Node) -> Str = { "visitor" }
}

impl Walker[Node] = {
  fn visit(x: Node) -> Str = { "walker" }
}

let n: Node = { id: 1 }
n.visit()  # error: Ambiguous
