trait Greet[a] = {
  fn hello(x: a) -> Str
  fn goodbye(x: a) -> Str
}

type Person = { name: Str }

impl Greet[Person] = {
  fn hello(x: Person) -> Str = { "hi " + x.name }
  fn goodbye(x: Person) -> Str = { "bye " + x.name }
}

let p = {name: "alice"}

puts(Greet.hello(p))  # output: hi alice
puts(Greet.goodbye(p))  # output: bye alice
