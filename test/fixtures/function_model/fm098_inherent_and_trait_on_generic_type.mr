enum Opt[a] = { Some(a), None }

trait Unwrapper[a] = {
  fn get(x: a) -> Int
}

impl Unwrapper[Opt[Int]] = {
  fn get(x: Opt[Int]) -> Int = match x {
    case Opt.Some(v): v
    case Opt.None: 0
  }
}

impl Opt[Int] = {
  fn get(o: Opt[Int]) -> Int = match o {
    case Opt.Some(v): v
    case Opt.None: -1
  }
}

let x = Opt.Some(42)
puts(x.get())  # output: 42
