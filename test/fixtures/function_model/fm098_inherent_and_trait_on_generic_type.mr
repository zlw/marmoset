type Opt[a] = { Some(a), None }

trait Label[a] = {
  fn tag(x: a) -> Str
}

impl[a] Label[Opt[a]] = {
  fn tag(x: Opt[a]) -> Str = match x {
    case Opt.Some(_): "trait:some"
    case Opt.None: "trait:none"
  }
}

impl[a] Opt[a] = {
  fn tag(o: Opt[a]) -> Str = match o {
    case Opt.Some(_): "inherent:some"
    case Opt.None: "inherent:none"
  }
}

let x = Opt.Some(42)
puts(Label.tag(x))  # output: trait:some
puts(Opt.tag(x))  # output: inherent:some
