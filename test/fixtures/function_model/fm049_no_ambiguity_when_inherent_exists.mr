type Cell = { v: Int }

trait Render[a] = {
  fn draw(x: a) -> Str
}

impl Render[Cell] = {
  fn draw(x: Cell) -> Str = { "trait" }
}

impl Cell = {
  fn draw(c: Cell) -> Str = { "inherent" }
}

let c = {v: 1}

# dot sugar is ambiguous here; explicit targets stay stable
puts(Render.draw(c))  # output: trait
puts(Cell.draw(c))  # output: inherent
