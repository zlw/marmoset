type Point = { x: Int, y: Int }
enum Flag = { On, Off }

impl Str = {
  fn loud(s: Str) -> Str = {
    s + "!"
  }
}

impl Point = {
  fn sum(p: Point) -> Int = { p.x + p.y }
}

impl Flag = {
  fn is_on(f: Flag) -> Bool = match f {
    case Flag.On: true
    case Flag.Off: false
  }
}

let s = "hi"
puts(s.loud())  # output: hi!
let p = Point(x: 1, y: 2)

puts(p.sum())  # output: 3
let f = Flag.On
puts(f.is_on())  # output: true
