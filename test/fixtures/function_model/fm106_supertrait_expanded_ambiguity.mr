# xfail: supertrait-expanded ambiguity not implemented
trait Base[a] = {
  fn op(x: a) -> Int
}

trait ChildA[a]: Base = {
  fn extra_a(x: a) -> Str
}

trait ChildB[a]: Base = {
  fn extra_b(x: a) -> Str
}

type Thing = { v: Int }

impl ChildA[Thing] = {
  fn extra_a(x: Thing) -> Str = { "a" }
  fn op(x: Thing) -> Int = { 1 }
}

impl ChildB[Thing] = {
  fn extra_b(x: Thing) -> Str = { "b" }
  fn op(x: Thing) -> Int = { 2 }
}

let t: Thing = { v: 0 }
# op is provided by both ChildA and ChildB via Base → ambiguity
t.op()  # error: Ambiguous
