type Thing = { v: Int }

trait Alpha[a] = {
  fn op(x: a) -> Int
}

impl Alpha[Thing] = {
  fn op(x: Thing) -> Int = { x.v }
}

# This definition should be accepted (no error at definition time)
impl Thing = {
  fn op(t: Thing) -> Int = { t.v + 1 }
}

let t = {v: 10}

puts(Show.show(Thing.op(t)))  # output: 11
