type Item = { v: Int }

trait Alpha[a] = {
  fn tag(x: a) -> Str
}

trait Beta[a] = {
  fn tag(x: a) -> Str
}

impl Alpha[Item] = {
  fn tag(x: Item) -> Str = {
    "alpha"
  }
}

impl Beta[Item] = {
  fn tag(x: Item) -> Str = {
    "beta"
  }
}

let i: Item = { v: 1 }
puts(Alpha.tag(i))  # output: alpha
puts(Beta.tag(i))  # output: beta
