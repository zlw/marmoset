type Val = { v: Int }

impl Val = {
  fn convert[b](x: Val, f: (Int) -> b) -> b = {
    f(x.v)
  }
}

let v: Val = {v: 42}

fn show_int(n: Int) -> Str = Show.show(n)
fn positive(n: Int) -> Bool = n > 0

let inferred: Str = Val.convert(v, show_int)
let explicit: Bool = Val.convert[Bool](v, positive)
puts(inferred)  # output: 42
puts(explicit)  # output: true
