type Val = { n: Int }

trait FmtA[a] = {
  fn fmt(x: a) -> Str
}

trait FmtB[a] = {
  fn fmt(x: a) -> Str
}

impl FmtA[Val] = {
  fn fmt(x: Val) -> Str = { "a:" + x.n.show() }
}

impl FmtB[Val] = {
  fn fmt(x: Val) -> Str = { "b:" + x.n.show() }
}

let v = Val(n: 5)

# These qualified forms should select the specific trait
puts(FmtA.fmt(v))  # output: a:5
puts(FmtB.fmt(v))  # output: b:5
