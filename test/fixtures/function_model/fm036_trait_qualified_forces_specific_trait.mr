type val = { n: int }

trait fmt_a[a] {
  fn fmt(x: a) -> string
}

trait fmt_b[a] {
  fn fmt(x: a) -> string
}

impl fmt_a for val {
  fn fmt(x: val) -> string { "a:" + x.n.show() }
}

impl fmt_b for val {
  fn fmt(x: val) -> string { "b:" + x.n.show() }
}

let v: val = { n: 5 }
# These qualified forms should select the specific trait
puts(fmt_a.fmt(v))  # output: a:5
puts(fmt_b.fmt(v))  # output: b:5
