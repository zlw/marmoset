enum Color = { Red, Green, Blue }

trait Describe[a] = {
  fn desc(x: a) -> Str
}

impl Describe[Color] = {
  fn desc(x: Color) -> Str = { "trait" }
}

impl Color = {
  fn desc(c: Color) -> Str = { "inherent" }
}

let c = Color.Red
puts(Describe.desc(c))  # output: trait
puts(Color.desc(c))  # output: inherent
