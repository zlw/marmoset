type Box = { v: Int }

impl Box = {
  fn as_type[b](bx: Box, f: (Int) -> b) -> b = {
    f(bx.v)
  }
}

let b: Box = {v: 42}

# Two different specializations of the same method generic
let s = Box.as_type(b, (n: Int) -> Show.show(n))
let i = Box.as_type(b, (n: Int) -> n + 1)
puts(s)  # output: 42
puts(i)  # output: 43
