type Box = { v: Int }

impl Box = {
  fn as_type[b](bx: Box, f: (Int) -> b) -> b = {
    f(bx.v)
  }
}

let b = Box(v: 42)

# Two different specializations of the same method generic
let s = b.as_type((n: Int) -> n.show())
let i = b.as_type((n: Int) -> n + 1)
puts(s)  # output: 42
puts(i)  # output: 43
