type Item = { v: Int }

trait Label[a] = {
  fn name(x: a) -> Str
}

impl Label[Item] = {
  fn name(x: Item) -> Str = { "trait:" + x.v.show() }
}

impl Item = {
  fn name(i: Item) -> Str = { "inherent:" + i.v.show() }
}

let i: Item = { v: 3 }
# dot call → inherent
puts(i.name())  # output: inherent:3
# qualified call → specific trait
puts(Label.name(i))  # output: trait:3
