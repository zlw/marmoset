type Item = { v: Int }

trait Label[a] = {
  fn name(x: a) -> Str
}

impl Label[Item] = {
  fn name(x: Item) -> Str = { "trait:" + x.v.show() }
}

impl Item = {
  fn name(i: Item) -> Str = { "inherent:" + i.v.show() }
}

let i = {v: 3}

# qualified calls remain explicit and stable
puts(Label.name(i))  # output: trait:3
puts(Item.name(i))  # output: inherent:3
