type Data = { v: Int }

trait Fmt[a] = {
  fn show_val(x: a) -> Str
}

impl Fmt[Data] = {
  fn show_val(x: Data) -> Str = { "trait:" + x.v.show() }
}

impl Data = {
  fn show_val(d: Data) -> Str = { "inherent:" + d.v.show() }
}

let d = {v: 7}

# dot sugar is ambiguous here; explicit targets stay stable
puts(Fmt.show_val(d))  # output: trait:7
puts(Data.show_val(d))  # output: inherent:7
