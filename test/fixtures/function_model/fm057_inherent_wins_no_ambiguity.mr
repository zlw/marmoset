type Data = { v: Int }

trait Fmt[a] = {
  fn show_val(x: a) -> Str
}

impl Fmt[Data] = {
  fn show_val(x: Data) -> Str = { "trait:" + x.v.show() }
}

impl Data = {
  fn show_val(d: Data) -> Str = { "inherent:" + d.v.show() }
}

let d = {v: 7}

# inherent wins, NOT ambiguity
puts(d.show_val())  # output: inherent:7
