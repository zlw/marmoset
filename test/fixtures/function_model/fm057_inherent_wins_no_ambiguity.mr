type Data = { v: Int }

trait Fmt[a] = {
  fn show_val(x: a) -> Str
}

impl Fmt[Data] = {
  fn show_val(x: Data) -> Str = { "trait:" + Show.show(x.v) }
}

impl Data = {
  fn show_val(d: Data) -> Str = { "inherent:" + Show.show(d.v) }
}

let d = {v: 7}

# explicit targets stay stable
puts(Fmt.show_val(d))  # output: trait:7
puts(Data.show_val(d))  # output: inherent:7
