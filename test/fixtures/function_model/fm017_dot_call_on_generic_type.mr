type Maybe[a] = { Just(a), Nothing }

impl[a] Maybe[a] = {
  fn is_just(m: Maybe[a]) -> Bool = match m {
    case Maybe.Just(_): true
    case Maybe.Nothing: false
  }
}

let x = Maybe.Just(42)
puts(Maybe.is_just(x))  # output: true
let y: Maybe[Int] = Maybe.Nothing
puts(Maybe.is_just(y))  # output: false
