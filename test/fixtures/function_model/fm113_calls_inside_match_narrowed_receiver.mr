type Shape = { Circle(Int), Rect(Int, Int) }

impl Shape = {
  fn area(s: Shape) -> Int = match s {
    case Shape.Circle(r): r * r * 3
    case Shape.Rect(w, h): w * h
  }
}

let s = Shape.Rect(4, 5)
let a = match s {
  case Shape.Circle(_): Shape.area(s)
  case Shape.Rect(_, _): Shape.area(s)
}
puts(a)  # output: 20
