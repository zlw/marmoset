# FM133: Default trait method calls required method even when a field shares the name
trait Greet[a] = {
  fn name(x: a) -> Str
  fn greet(x: a) -> Str = "hi " + x.name()
}

type Person = { name: Str }

impl Greet[Person] = {
  fn name(x: Person) -> Str = x.name
}

let p: Person = { name: "alice" }
puts(p.greet())  # output: hi alice
