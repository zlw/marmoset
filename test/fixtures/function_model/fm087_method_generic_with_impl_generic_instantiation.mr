type Result[a, b] = { Ok(a), Err(b) }

impl[a, b] Result[a, b] = {
  fn map_ok[c](r: Result[a, b], f: (a) -> c) -> Result[c, b] = match r {
    case Result.Ok(v): Result.Ok(f(v))
    case Result.Err(e): Result.Err(e)
  }
}

# impl generics: a=Int, b=Str; method generic: c=Bool
let r: Result[Int, Str] = Result.Ok(42)
let r2: Result[Bool, Str] = Result.map_ok(r, (n: Int) -> n > 0)
