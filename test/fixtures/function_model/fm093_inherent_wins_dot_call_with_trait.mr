type Cell = { v: Int }

trait Info[a] = {
  fn detail(x: a) -> Str
}

impl Info[Cell] = {
  fn detail(x: Cell) -> Str = { "trait:" + x.v.show() }
}

impl Cell = {
  fn detail(c: Cell) -> Str = { "inherent:" + c.v.show() }
}

let c = {v: 5}

puts(Info.detail(c))  # output: trait:5
puts(Cell.detail(c))  # output: inherent:5
