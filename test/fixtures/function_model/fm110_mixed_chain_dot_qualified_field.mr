type Counter = { n: Int, fmt: (Int) -> Str }

trait Display[a] = {
  fn render(x: a) -> Str
}

impl Display[Counter] = {
  fn render(x: Counter) -> Str = { "display:" + x.n.show() }
}

impl Counter = {
  fn value(c: Counter) -> Int = { c.n }
}

let fmt_fn = (n: Int) -> "n=" + n.show()
let c = {n: 5, fmt: fmt_fn}


# dot call (inherent)
let v = c.value()
# field-function fallback
let s = c.fmt(v)
# qualified trait call
let d = Display.render(c)
puts(s)  # output: n=5
puts(d)  # output: display:5
