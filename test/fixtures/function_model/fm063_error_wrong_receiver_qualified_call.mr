# FM63: Qualified trait call rejects wrong nominal receiver
# Under nominal named-type semantics Alpha and Beta are distinct types.
type Alpha = { v: Int }
type Beta = { v: Int }

trait Label[a] = {
  fn tag(x: a) -> Str
}

impl Label[Alpha] = {
  fn tag(x: Alpha) -> Str = { "alpha" }
}

let b = Beta(v: 1)

puts(Label.tag(b))  # error: does not implement trait
