enum Either[a, b] = { Left(a), Right(b) }

impl[a, b] Either[a, b] = {
  fn is_left(e: Either[a, b]) -> Bool = match e {
    case Either.Left(_): true
    case Either.Right(_): false
  }
}

let x = Either.Left(42)
puts(x.is_left())  # output: true
let y: Either[Int, Str] = Either.Right("hi")
puts(y.is_left())  # output: false
