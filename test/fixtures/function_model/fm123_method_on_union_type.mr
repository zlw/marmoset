enum either[a, b] { left(a) right(b) }

impl either[a, b] {
  fn is_left(e: either[a, b]) -> bool {
    match e {
      either.left(_): true
      either.right(_): false
    }
  }
}

let x = either.left(42)
puts(x.is_left())  # output: true
let y: either[int, string] = either.right("hi")
puts(y.is_left())  # output: false
