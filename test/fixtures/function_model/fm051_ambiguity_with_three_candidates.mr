type thing = { v: int }

trait p1[a] { fn go(x: a) -> string }
trait p2[a] { fn go(x: a) -> string }
trait p3[a] { fn go(x: a) -> string }

impl p1 for thing { fn go(x: thing) -> string { "1" } }
impl p2 for thing { fn go(x: thing) -> string { "2" } }
impl p3 for thing { fn go(x: thing) -> string { "3" } }

let t: thing = { v: 0 }
t.go()  # error: Ambiguous
