type Thing = { v: Int }

trait P1[a] = { fn go(x: a) -> Str }
trait P2[a] = { fn go(x: a) -> Str }
trait P3[a] = { fn go(x: a) -> Str }

impl P1[Thing] = { fn go(x: Thing) -> Str = { "1" } }
impl P2[Thing] = { fn go(x: Thing) -> Str = { "2" } }
impl P3[Thing] = { fn go(x: Thing) -> Str = { "3" } }

let t = {v: 0}

t.go()  # error: not a callable field
