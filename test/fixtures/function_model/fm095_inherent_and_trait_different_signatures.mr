type Data = { v: Int }

trait Summarize[a] = {
  fn info(x: a) -> Str
}

impl Summarize[Data] = {
  fn info(x: Data) -> Str = { x.v.show() }
}

impl Data = {
  fn info(d: Data) -> Int = { d.v }
}

let d = {v: 42}

# explicit calls disambiguate the different signatures
puts(Summarize.info(d))  # output: 42
puts(Data.info(d).show())  # output: 42
