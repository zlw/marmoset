type Data = { v: Int }

trait Summarize[a] = {
  fn info(x: a) -> Str
}

impl Summarize[Data] = {
  fn info(x: Data) -> Str = { x.v.show() }
}

impl Data = {
  fn info(d: Data) -> Int = { d.v }
}

let d = Data(v: 42)

# inherent returns int, trait returns string — different signatures OK
puts(d.info())  # output: 42
