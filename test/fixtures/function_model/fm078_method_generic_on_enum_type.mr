enum Maybe[a] = { Just(a), Nothing }

impl[a] Maybe[a] = {
  fn map[b](m: Maybe[a], f: (a) -> b) -> Maybe[b] = match m {
    case Maybe.Just(v): Maybe.Just(f(v))
    case Maybe.Nothing: Maybe.Nothing
  }

  fn unwrap_or(m: Maybe[a], default: a) -> a = match m {
    case Maybe.Just(v): v
    case Maybe.Nothing: default
  }
}

let x = Maybe.Just(42)
let y = x.map((n: Int) -> n.show())
