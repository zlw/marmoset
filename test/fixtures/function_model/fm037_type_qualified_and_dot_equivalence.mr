type Pair = { a: Int, b: Int }

impl Pair = {
  fn total(p: Pair) -> Int = {
    p.a + p.b
  }
}

let p = {a: 10, b: 20}

# These two forms should produce identical results
let total = Pair.total
let via_value = total(p)
let via_qual = Pair.total(p)
puts(via_value)  # output: 30
puts(via_qual)  # output: 30
