type Counter = { n: Int }

trait Display[a] = { fn render(x: a) -> Str }

impl Display[Counter] = {
  fn render(x: Counter) -> Str = {
    "display:" + x.n.show()
  }
}

impl Counter = {
  fn render(c: Counter) -> Str = {
    "counter:" + c.n.show()
  }
}

let c = {n: 5}

# dot sugar is ambiguous here; explicit targets stay stable
puts(Display.render(c))  # output: display:5
puts(Counter.render(c))  # output: counter:5
