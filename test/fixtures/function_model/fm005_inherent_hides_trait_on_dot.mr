type Counter = { n: Int }

trait Display[a] = { fn render(x: a) -> Str }

impl Display[Counter] = {
  fn render(x: Counter) -> Str = {
    "display:" + x.n.show()
  }
}

impl Counter = {
  fn render(c: Counter) -> Str = {
    "counter:" + c.n.show()
  }
}

let c = Counter(n: 5)

# inherent wins on dot call
puts(c.render())  # output: counter:5
