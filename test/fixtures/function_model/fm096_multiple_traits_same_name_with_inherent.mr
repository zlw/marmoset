type Val = { n: Int }

trait FmtA[a] = { fn fmt(x: a) -> Str }
trait FmtB[a] = { fn fmt(x: a) -> Str }

impl FmtA[Val] = {
  fn fmt(x: Val) -> Str = { "a" }
}

impl FmtB[Val] = {
  fn fmt(x: Val) -> Str = { "b" }
}

impl Val = {
  fn fmt(v: Val) -> Str = { "inherent" }
}

let v = {n: 1}

# dot sugar is ambiguous here; explicit targets stay stable
puts(FmtA.fmt(v))  # output: a
puts(FmtB.fmt(v))  # output: b
puts(Val.fmt(v))  # output: inherent
