type val = { n: int }

trait fmt_a[a] { fn fmt(x: a) -> string }
trait fmt_b[a] { fn fmt(x: a) -> string }

impl fmt_a for val {
  fn fmt(x: val) -> string { "a" }
}

impl fmt_b for val {
  fn fmt(x: val) -> string { "b" }
}

impl val {
  fn fmt(v: val) -> string { "inherent" }
}

let v: val = { n: 1 }
# inherent wins on dot, no ambiguity
puts(v.fmt())  # output: inherent
