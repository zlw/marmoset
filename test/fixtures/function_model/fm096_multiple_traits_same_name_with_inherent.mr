type Val = { n: Int }

trait FmtA[a] = { fn fmt(x: a) -> Str }
trait FmtB[a] = { fn fmt(x: a) -> Str }

impl FmtA[Val] = {
  fn fmt(x: Val) -> Str = { "a" }
}

impl FmtB[Val] = {
  fn fmt(x: Val) -> Str = { "b" }
}

impl Val = {
  fn fmt(v: Val) -> Str = { "inherent" }
}

let v: Val = { n: 1 }
# inherent wins on dot, no ambiguity
puts(v.fmt())  # output: inherent
