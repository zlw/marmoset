# xfail: enum qualified inherent method not implemented
enum Box = { Val(Int), Empty }

impl Box = {
  fn describe(b: Box) -> Str = match b {
    case Box.Val(n): "val:" + n.show()
    case Box.Empty: "empty"
  }
}

# variant constructor path
let b = Box.Val(42)
# inherent method via type qualification
puts(Box.describe(b))  # output: val:42
