type Widget = { v: Int }

trait Describe[a] = { fn info(x: a) -> Str }

impl Describe[Widget] = {
  fn info(x: Widget) -> Str = {
    "trait:" + x.v.show()
  }
}

impl Widget = {
  fn info(w: Widget) -> Str = {
    "inherent:" + w.v.show()
  }
}

let w = {v: 42}

puts(w.info())  # output: inherent:42
