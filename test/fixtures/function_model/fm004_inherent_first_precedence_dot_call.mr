type Widget = { v: Int }

trait Describe[a] = { fn info(x: a) -> Str }

impl Describe[Widget] = {
  fn info(x: Widget) -> Str = {
    "trait:" + Show.show(x.v)
  }
}

impl Widget = {
  fn info(w: Widget) -> Str = {
    "inherent:" + Show.show(w.v)
  }
}

let w = {v: 42}

puts(Describe.info(w))  # output: trait:42
puts(Widget.info(w))  # output: inherent:42
