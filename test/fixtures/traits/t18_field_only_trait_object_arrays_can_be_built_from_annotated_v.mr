# T18: Field-only trait object arrays can be built from annotated values
trait Named = {
  name: Str
}
let person: Named = { name: "alice", age: 42 }  # error: cannot be used as a type in vNext
let company: Named = { name: "acme", employees: 10 }
let xs: List[Named] = [person, company]
puts(xs[1].name)  # output: acme
