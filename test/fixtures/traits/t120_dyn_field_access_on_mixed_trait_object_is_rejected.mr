# T120: Legacy mixed field+method trait syntax is rejected before Dyn field access
type Person = { name: Str }
trait NamedShow[a] = {
  name: Str  # error: Trait bodies are method-only; use 'shape' for structural field contracts
  fn show(x: a) -> Str
}
impl NamedShow[Person] = {
  fn show(x: Person) -> Str = x.name
}
let x: Dyn[NamedShow] = { name: "alice" }
x.name
