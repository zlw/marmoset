# T72: Supertrait: Ord constraint also requires Eq transitively
trait Eq[a] = {  # error: supertrait
  fn eq(x: a, y: a) -> Bool
}
trait Ord[a]: Eq = {
  fn compare(x: a, y: a) -> Int
}
type Point = { x: Int }
impl Ord[Point] = {
  fn compare(x: Point, y: Point) -> Int = 0
}
fn compare_self[a: Ord](x: a) -> Int = x.compare(x)
let p: Point = { x: 1 }
puts(compare_self(p))
