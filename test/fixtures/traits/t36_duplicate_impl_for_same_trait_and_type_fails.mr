# T36: Duplicate impl for same trait and type fails
trait show[a] {  # error: Duplicate impl for trait
       fn show(x: a) -> string
     }
     impl show for int {
       fn show(x: int) -> string {
         "first"
       }
     }
     impl show for int {
       fn show(x: int) -> string {
         "second"
       }
     }
     42
