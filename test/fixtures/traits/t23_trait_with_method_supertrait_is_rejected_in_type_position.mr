# xfail: legacy bare trait-as-type syntax was removed by syntax-rework; method trait objects move to follow-up Dyn syntax
# T23: Trait with method supertrait is rejected in type position
trait Named = {  # error: method and mixed trait objects are not supported in this phase
  name: Str
}
trait Show[a] = {
  fn show(x: a) -> Str
}
trait NamedShow: Named & Show = {}
let x: NamedShow = { name: "alice" }
