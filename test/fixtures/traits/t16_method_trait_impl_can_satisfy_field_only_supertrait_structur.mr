# T16: Method trait impl can satisfy field-only supertrait structurally
type Person = { name: Str, age: Int }
trait Named = {
  name: Str
}
trait Shown[a]: Named = {
  fn show(x: a) -> Str
}
impl Shown[Person] = {
  fn show(x: Person) -> Str = x.name
}
let p: Person = { name: "alice", age: 42 }
puts(p.show())  # output: alice
