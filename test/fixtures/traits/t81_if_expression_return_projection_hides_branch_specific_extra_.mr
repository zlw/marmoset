# T81: If-expression return projection hides branch-specific extra fields
trait Named = {
  name: Str  # error: Trait bodies are method-only; move structural fields to a shape declaration
}
let x: Named = if (true) { { name: "branch_a", extra1: 1 } } else { { name: "branch_b", extra2: "two" } }
puts(x.extra1)
