# xfail: bare trait-as-type semantics are deferred to syntax-rework-followup Dyn syntax
# T81: If-expression return projection hides branch-specific extra fields
trait Named = {
  name: Str
}
fn pick(flag: Bool) -> Named = {
  if (flag) {
    { name: "branch_a", extra1: 1 }
  } else {
    { name: "branch_b", extra2: "two" }
  }
}
let x = pick(true)
puts(x.extra1)  # error: Record field 'extra1' not found in type
