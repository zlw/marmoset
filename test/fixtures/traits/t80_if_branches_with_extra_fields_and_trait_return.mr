# xfail: bare trait-as-type semantics are deferred to syntax-rework-followup Dyn syntax
# T80: If branches with extra fields and trait return
trait Named = {
  name: Str
}
fn describe(age: Int) -> Named = {
  if (age < 30) {
    { name: "young", category: "a" }
  } else {
    { name: "old", category: "b" }
  }
}
let x = describe(25)
puts(x.name)  # output: young
