# T80: If branches with extra fields and trait return
trait Named = {
  name: Str
}
fn describe(age: Int) -> Named = {  # error: cannot be used as a type in vNext
  if (age < 30) {
    { name: "young", category: "a" }
  } else {
    { name: "old", category: "b" }
  }
}
let x = describe(25)
puts(x.name)  # output: young
