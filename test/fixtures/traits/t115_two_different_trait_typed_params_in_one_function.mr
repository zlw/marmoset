# T115: Two different trait-typed params in one function
trait Named = {
  name: Str  # error: Trait bodies are method-only; use 'shape' for structural field contracts
}
trait Scored = {
  score: Int
}
fn describe(n: Named, s: Scored) -> Str = n.name + " " + s.score.show()
puts(describe({ name: "alice", id: 1 }, { score: 42, rank: "A" }))  # output: alice 42
