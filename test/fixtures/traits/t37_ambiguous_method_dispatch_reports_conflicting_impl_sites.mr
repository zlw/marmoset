# T37: Ambiguous method dispatch reports conflicting impl sites
trait RenderA[a] = {
  fn render(x: a) -> Str
}
trait RenderB[a] = {
  fn render(x: a) -> Str
}
impl RenderA[Int] = {
  fn render(x: Int) -> Str = "a"
}
impl RenderB[Int] = {
  fn render(x: Int) -> Str = "b"
}
let x = 1
puts(x.render())  # error: not a callable field
