# xfail: legacy bare trait-as-type syntax was removed by syntax-rework; method trait objects move to follow-up Dyn syntax
# T116: Field-only trait as both constraint and type annotation
trait Named = {
  name: Str
}
fn get_name[t: Named](x: t) -> Str = x.name
let p: Named = { name: "alice", age: 30 }
puts(p.name + " " + get_name({ name: "bob", role: "admin" }))  # output: alice bob
