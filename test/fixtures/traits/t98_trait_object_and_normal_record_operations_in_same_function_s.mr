# T98: Trait object and normal record operations in same function scope
trait Named = {
  name: Str  # error: Trait bodies are method-only; use 'shape' for structural field contracts
}
fn process(x: Named, extra: Int) -> Str = {
  let n = x.name
  let plain = { value: extra }
  n + " " + Show.show(plain.value)
}
puts(process({ name: "alice", age: 30 }, 42))  # output: alice 42
