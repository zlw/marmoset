# xfail: bare trait-as-type semantics are deferred to syntax-rework-followup Dyn syntax
# T78: Return type projection hides non-trait fields at typecheck
trait Named = {
  name: Str
}
fn mk_named(n: Str, a: Int) -> Named = { name: n, age: a }
let x = mk_named("alice", 30)
puts(x.age)  # error: Record field 'age' not found in type
