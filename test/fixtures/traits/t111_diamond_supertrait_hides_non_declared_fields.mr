# T111: Diamond supertrait hides non-declared fields
trait Named = {
  name: Str
}
trait Worker: Named = {
  job: Str
}
trait Resident: Named = {
  city: Str
}
trait Citizen: Worker & Resident = {}
let x: Citizen = { name: "alice", job: "eng", city: "sf", extra: true }  # error: cannot be used as a type in vNext
puts(x.extra)
