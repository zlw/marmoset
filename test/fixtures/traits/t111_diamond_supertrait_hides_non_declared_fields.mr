# T111: Diamond supertrait hides non-declared fields
trait Named = {
  name: Str  # error: Trait bodies are method-only; use 'shape' for structural field contracts
}
trait Worker: Named = {
  job: Str
}
trait Resident: Named = {
  city: Str
}
trait Citizen: Worker & Resident = {}
let x: Citizen = { name: "alice", job: "eng", city: "sf", extra: true }
puts(x.extra)
