# xfail: bare trait-as-type semantics are deferred to syntax-rework-followup Dyn syntax
# T111: Diamond supertrait hides non-declared fields
trait Named = {
  name: Str
}
trait Worker: Named = {
  job: Str
}
trait Resident: Named = {
  city: Str
}
trait Citizen: Worker & Resident = {}
let x: Citizen = { name: "alice", job: "eng", city: "sf", extra: true }
puts(x.extra)  # error: Record field 'extra' not found in type
