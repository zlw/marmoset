# xfail: bare trait-as-type semantics are deferred to syntax-rework-followup Dyn syntax
# T29: Field-only trait object in list still hides non-projected fields
trait Named = {
  name: Str
}
let a: Named = { name: "alice", age: 1 }
let b: Named = { name: "bob", age: 2 }
let xs: List[Named] = [a, b]
puts(xs[0].age)  # error: Record field 'age' not found in type
