# T29: Legacy field-style trait syntax is rejected before list projection rules apply
trait Named = {
  name: Str  # error: Trait bodies are method-only; use 'shape' for structural field contracts
}
let a: Named = { name: "alice", age: 1 }
let b: Named = { name: "bob", age: 2 }
let xs: List[Named] = [a, b]
puts(xs[0].age)
