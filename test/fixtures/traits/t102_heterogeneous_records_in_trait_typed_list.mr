# xfail: legacy bare trait-as-type syntax was removed by syntax-rework; method trait objects move to follow-up Dyn syntax
# T102: Heterogeneous records in trait-typed list
trait Named = {
  name: Str
}
let a: Named = { name: "alice", role: "admin" }
let b: Named = { name: "bob", age: 30 }
let xs: List[Named] = [a, b]
puts(xs[0].name + " " + xs[1].name)  # output: alice bob
