# xfail: bare trait-as-type semantics are deferred to syntax-rework-followup Dyn syntax
# T103: List of trait objects hides non-projected fields on element access
trait Named = {
  name: Str
}
let a: Named = { name: "alice", role: "admin" }
let xs: List[Named] = [a]
puts(xs[0].role)  # error: Record field 'role' not found in type
