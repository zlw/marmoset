# T71: Supertrait: methods from supertrait available through Ord constraint
trait Eq[a] = {
  fn eq(x: a, y: a) -> Bool
}
trait Ord[a]: Eq = {
  fn compare(x: a, y: a) -> Int
}
type Point = { x: Int }
impl Eq[Point] = {
  fn eq(x: Point, y: Point) -> Bool = x.x == y.x
}
impl Ord[Point] = {
  fn compare(x: Point, y: Point) -> Int = 0
}
fn eq_via_ord[a: Ord](x: a, y: a) -> Bool = x.eq(y)
let p1: Point = { x: 1 }
let p2: Point = { x: 1 }
puts(eq_via_ord(p1, p2))  # output: true
