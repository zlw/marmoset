# T74: Multiple trait-typed parameters in same function
trait Named = {
  name: Str  # error: Trait bodies are method-only; use 'shape' for structural field contracts
}
fn greet_both(a: Named, b: Named) -> Str = a.name + " " + b.name
puts(greet_both({ name: "alice", age: 30 }, { name: "bob", role: "admin" }))  # output: alice bob
