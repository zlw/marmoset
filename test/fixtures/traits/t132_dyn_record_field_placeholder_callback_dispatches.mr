# T132: Dyn trait-object fields package direct values before placeholder callbacks consume them
type Box[a] = { value: a }

impl[a] Box[a] = {
  fn map[b](box: Box[a], f: (a) -> b) -> b = f(box.value)
}

let value: Dyn[Show & Eq] = 42
let box = Box(value: value)
puts(box.map(_.show()))  # output: 42
