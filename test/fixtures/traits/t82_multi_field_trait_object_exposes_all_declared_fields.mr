# xfail: legacy bare trait-as-type syntax was removed by syntax-rework; method trait objects move to follow-up Dyn syntax
# T82: Multi-field trait object exposes all declared fields
trait PersonLike = {
  name: Str
  age: Int
}
let x: PersonLike = { name: "alice", age: 30, active: true }
puts(x.name + " " + x.age.show())  # output: alice 30
