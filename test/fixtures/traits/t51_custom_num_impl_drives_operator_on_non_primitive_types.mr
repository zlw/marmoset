# T51: Custom num impl drives + operator on non-primitive types
enum boxed {
  val(int)
}
impl num for boxed {
  fn add(x: boxed, y: boxed) -> boxed { x }
  fn sub(x: boxed, y: boxed) -> boxed { x }
  fn mul(x: boxed, y: boxed) -> boxed { x }
  fn div(x: boxed, y: boxed) -> boxed { x }
}
let a = boxed.val(13)
let b = boxed.val(2)
match (a + b) {  # output: 13
  boxed.val(n): puts(n)
}
