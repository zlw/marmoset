# T13: Mixed field+method constraints still enforce method trait obligations
trait named {  # error: does not implement trait shown
  name: string
}
trait shown[a] {
  fn show(x: a) -> string
}
let get_name = fn[t: named + shown](x: t) -> string {
  x.name
};
let p = { name: "alice" }
puts(get_name(p))
