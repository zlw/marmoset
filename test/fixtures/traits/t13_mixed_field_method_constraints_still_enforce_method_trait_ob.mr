# T13: Legacy mixed field+method trait syntax is rejected; split fields into a shape
trait Named = {
  name: Str  # error: Trait bodies are method-only; use 'shape' for structural field contracts
}
trait Shown[a] = {
  fn show(x: a) -> Str
}
fn get_name[t: Named & Shown](x: t) -> Str = x.name
let p = { name: "alice" }
puts(get_name(p))
