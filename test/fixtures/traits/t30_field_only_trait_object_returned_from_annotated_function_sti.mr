# xfail: bare trait-as-type semantics are deferred to syntax-rework-followup Dyn syntax
# T30: Field-only trait object returned from annotated function still hides non-projected fields
trait Named = {
  name: Str
}
fn mk(age: Int) -> Named = { name: "alice", age: age }
let x = mk(1)
puts(x.age)  # error: Record field 'age' not found in type
