# xfail: legacy bare trait-as-type syntax was removed by syntax-rework; method trait objects move to follow-up Dyn syntax
# T109: Diamond supertrait inherits shared field once
trait Named = {
  name: Str
}
trait Worker: Named = {
  job: Str
}
trait Resident: Named = {
  city: Str
}
trait Citizen: Worker & Resident = {}
let x: Citizen = { name: "alice", job: "eng", city: "sf", extra: true }
puts(x.name)  # output: alice
