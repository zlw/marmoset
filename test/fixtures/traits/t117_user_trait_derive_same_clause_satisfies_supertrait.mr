# T117: User-trait derive can satisfy supertraits from the same derive clause
trait Base[a] = {
  fn base(self: a) -> Str = "base"
}

trait Child[a]: Base = {
  fn child(self: a) -> Str = Base.base(self)
}

type Score = Int derive Child, Base
let score: Score = 1
puts(Child.child(score))  # output: base
