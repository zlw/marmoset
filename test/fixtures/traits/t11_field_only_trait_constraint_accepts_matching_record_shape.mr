# T11: Legacy field-style trait syntax is rejected; use a shape constraint
trait Named = {
  name: Str  # error: Trait bodies are method-only; use 'shape' for structural field contracts
}
fn get_name[t: Named](x: t) -> Str = x.name
let person = { name: "alice", age: 42 }
puts(get_name(person))  # output: alice
