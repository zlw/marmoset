# xfail: legacy bare trait-as-type syntax was removed by syntax-rework; method trait objects move to follow-up Dyn syntax
# T107: Type alias to field-only trait hides non-trait fields
trait Named = {
  name: Str
}
type Nameable = Named
let x: Nameable = { name: "alice", age: 30 }
puts(x.age)  # error: Record field 'age' not found in type
