# xfail: legacy bare trait-as-type syntax was removed by syntax-rework; method trait objects move to follow-up Dyn syntax
# T90: Supertrait chain inherits parent fields
trait Named = {
  name: Str
}
trait Described: Named = {
  description: Str
}
let x: Described = { name: "alice", description: "a person", hobby: "chess" }
puts(x.name)  # output: alice
