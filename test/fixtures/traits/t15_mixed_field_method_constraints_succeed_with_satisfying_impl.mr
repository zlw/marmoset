# T15: Mixed field+method constraints succeed with satisfying impl
# output: alice
type person = { name: string, age: int }
trait named {
  name: string
}
trait shown[a] {
  fn show(x: a) -> string
}
impl shown for person {
  fn show(x: person) -> string {
    x.name
  }
}
let get_name = fn[t: named + shown](x: t) -> string {
  x.name
};
let p: person = { name: "alice", age: 42 }
puts(get_name(p))
