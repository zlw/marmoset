# T15: Legacy mixed field+method trait syntax is rejected; split fields into a shape
type Person = { name: Str, age: Int }
trait Named = {
  name: Str  # error: Trait bodies are method-only; use 'shape' for structural field contracts
}
trait Shown[a] = {
  fn show(x: a) -> Str
}
impl Shown[Person] = {
  fn show(x: Person) -> Str = x.name
}
fn get_name[t: Named & Shown](x: t) -> Str = x.name
let p: Person = { name: "alice", age: 42 }
puts(get_name(p))  # output: alice
