# xfail: bare trait-as-type semantics are deferred to syntax-rework-followup Dyn syntax
# T93: Three-level supertrait chain exposes all ancestor fields
trait Named = {
  name: Str
}
trait Aged: Named = {
  age: Int
}
trait Profiled: Aged = {
  status: Str
}
let x: Profiled = { name: "alice", age: 30, status: "active", secret: true }
puts(x.name + " " + x.age.show() + " " + x.status)  # output: alice 30 active
