# T19: Legacy field-style supertrait syntax is rejected
trait Named = {
  name: Str  # error: Trait bodies are method-only; use 'shape' for structural field contracts
}
trait Aged = {
  age: Int
}
trait Person: Named & Aged = {}
let p: Person = { name: "alice", age: 43, active: true }
puts(p.age)  # output: 43
