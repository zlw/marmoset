# xfail: legacy bare trait-as-type syntax was removed by syntax-rework; method trait objects move to follow-up Dyn syntax
# T19: Field-only trait object includes inherited fields from supertraits
trait Named = {
  name: Str
}
trait Aged = {
  age: Int
}
trait Person: Named & Aged = {}
let p: Person = { name: "alice", age: 43, active: true }
puts(p.age)  # output: 43
