# T131: Dyn grandchild trait objects expose transitive inherited methods
trait Base[a] = {
  fn base(self: a) -> Str = "base"
}

trait Child[a]: Base = {
  fn child(self: a) -> Str = Base.base(self) + ":child"
}

trait Loud[a]: Child = {
  fn loud(self: a) -> Str = Base.base(self) + ":" + Child.child(self)
}

impl Base[Int] = {}
impl Child[Int] = {}
impl Loud[Int] = {}

let value: Dyn[Loud] = 1
puts(Base.base(value))   # output: base
puts(Child.child(value))  # output: base:child
puts(Loud.loud(value))   # output: base:base:child
