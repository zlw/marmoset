# T131: Dyn grandchild trait objects expose transitive inherited methods
trait Base[a] = {
  fn base(self: a) -> Str = "base"
}

trait Child[a]: Base = {
  fn child(self: a) -> Str = self.base() + ":child"
}

trait Loud[a]: Child = {
  fn loud(self: a) -> Str = self.base() + ":" + self.child()
}

impl Base[Int] = {}
impl Child[Int] = {}
impl Loud[Int] = {}

let value: Dyn[Loud] = 1
puts(value.base())   # output: base
puts(value.child())  # output: base:child
puts(value.loud())   # output: base:base:child
