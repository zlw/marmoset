# T91: Supertrait chain: access child's own fields
trait Named = {
  name: Str  # error: Trait bodies are method-only; move structural fields to a shape declaration
}
trait Described: Named = {
  description: Str
}
let x: Described = { name: "alice", description: "a person", hobby: "chess" }
puts(x.description)  # output: a person
