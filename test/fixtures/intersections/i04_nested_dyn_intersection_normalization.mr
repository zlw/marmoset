# I04: Nested Dyn intersections flatten, sort, and dedupe on the general intersection surface
trait Render[a] = {
  fn render(x: a) -> Str
}
impl Render[Int] = {
  fn render(x: Int) -> Str = "render:" + Show.show(x)
}

let value: Dyn[Show] & (Dyn[Render] & Dyn[Show]) = 42
puts(Show.show(value))  # output: 42
puts(Render.render(value))  # output: render:42
