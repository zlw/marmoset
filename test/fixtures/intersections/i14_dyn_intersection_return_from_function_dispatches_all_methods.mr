# I14: Dyn-only intersections returned from functions package once and dispatch all methods
trait Render[a] = {
  fn render(x: a) -> Str
}

impl Render[Int] = {
  fn render(x: Int) -> Str = "render:" + Show.show(x)
}

fn box() -> Dyn[Show] & Dyn[Render] = 42
let value = box()
puts(Show.show(value))    # output: 42
puts(Render.render(value))  # output: render:42
