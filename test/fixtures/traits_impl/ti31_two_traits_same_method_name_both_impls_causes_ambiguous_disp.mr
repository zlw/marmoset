# TI31: Two traits same method name, both impls causes ambiguous dispatch
trait AlphaTrait[a] = {
  fn tag(x: a) -> Str
}
trait BetaTrait[a] = {
  fn tag(x: a) -> Str
}
impl AlphaTrait[Int] = {
  fn tag(x: Int) -> Str = "alpha"
}
impl BetaTrait[Int] = {
  fn tag(x: Int) -> Str = "beta"
}
puts(1.tag())  # error: Ambiguous
