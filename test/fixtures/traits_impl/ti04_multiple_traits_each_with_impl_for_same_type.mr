# TI04: Multiple traits each with impl for same type
trait Greet[a] = {
  fn greet(x: a) -> Str
}
trait Check[a] = {
  fn check(x: a) -> Bool
}
impl Greet[Str] = {
  fn greet(s: Str) -> Str = "hello"
}
impl Check[Str] = {
  fn check(s: Str) -> Bool = true
}
puts("world".greet())  # output: hello
puts("world".check())  # output: true
