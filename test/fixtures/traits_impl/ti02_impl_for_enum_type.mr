# TI02: Impl for enum type
enum Color = {
  Red,
  Green,
  Blue,
}
trait Show[a] = {
  fn show(x: a) -> Str
}
impl Show[Color] = {
  fn show(c: Color) -> Str = match c {
    case Color.Red: "red"
    case Color.Green: "green"
    case Color.Blue: "blue"
  }
}
let c = Color.Red
puts(Show.show(c))  # output: red
