# TI03: Multiple impls for same type (different traits)
trait Show[a] = {
  fn show(x: a) -> Str
}
trait Double[a] = {
  fn double(x: a) -> Int
}
impl Show[Int] = {
  fn show(x: Int) -> Str = "42"
}
impl Double[Int] = {
  fn double(x: Int) -> Int = x + x
}
puts(Show.show(1))  # output: 42
puts(Double.double(3) == 6)  # output: true
