# TI07: Impl method with multiple parameters
trait Eq[a] = {
  fn eq(x: a, y: a) -> Bool
}
type Point = { x: Int, y: Int }
impl Eq[Point] = {
  fn eq(a: Point, b: Point) -> Bool = {
    a.x == b.x
  }
}
let p1: Point = Point(x: 1, y: 2)
let p2: Point = Point(x: 1, y: 99)
puts(p1.eq(p2))  # output: true
