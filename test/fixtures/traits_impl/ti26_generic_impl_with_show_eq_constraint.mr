# TI26: Generic impl with Show+Eq constraint
trait Show[a] = {
  fn show(x: a) -> Str
}
trait Eq[a] = {
  fn eq(x: a, y: a) -> Bool
}
trait Describe[a] = {
  fn describe(x: a) -> Str
}
impl[b: Show & Eq] Describe[List[b]] = {
  fn describe(x: List[b]) -> Str = "ok"
}
puts(Describe.describe([1, 2]))  # output: ok
