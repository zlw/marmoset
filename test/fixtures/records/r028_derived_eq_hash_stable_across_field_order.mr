# R028: Derived eq/hash are stable across field order
type Point = { x: Int, y: Int } derive Eq, Hash
let p1: Point = {x: 1, y: 2}
let p2: Point = {y: 2, x: 1}
let out = if (Eq.eq(p1, p2)) {
  if (Hash.hash(p1) == Hash.hash(p2)) { "ok" } else { "hash_bad" }
} else {
  "eq_bad"
}
puts(out)  # output: ok
