# R120: Accumulator record pattern (non-recursive)
fn step1(acc) = { { sum: acc.sum + 1, count: acc.count + 1 } }
fn step2(acc) = { { sum: acc.sum + 4, count: acc.count + 1 } }
fn step3(acc) = { { sum: acc.sum + 10, count: acc.count + 1 } }
let init = { sum: 0, count: 0 }
let r = step3(step2(step1(init)))
puts(r.sum)  # output: 15
