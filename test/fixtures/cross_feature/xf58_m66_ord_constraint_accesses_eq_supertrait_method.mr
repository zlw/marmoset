# XF58: M66: Ord constraint accesses Eq supertrait method
type Point = { x: Int }
impl Eq[Point] = {
  fn eq(a: Point, b: Point) -> Bool = {
    a.x == b.x
  }
}
impl Ord[Point] = {
  fn compare(a: Point, b: Point) -> Ordering = {
    if (a.x < b.x) { ordering.less } else { if (a.x == b.x) { ordering.equal } else { ordering.greater } }
  }
}
fn same[a: Ord](x: a, y: a) -> Bool = {
  x.eq(y)
}
let p1: Point = { x: 42 }
let p2: Point = { x: 42 }
puts(same(p1, p2))  # output: true
