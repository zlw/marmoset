# XF22: E22: BUG: Recursive enum as param type annotation fails
enum MyList = { Cons(Int, MyList), Nil }  # error: Unknown type constructor: MyList
fn sum(xs: MyList) -> Int = {
  match xs {
    case MyList.Cons(h, t): h + sum(t)
    case MyList.Nil: 0
  }
}
let xs = MyList.Cons(1, MyList.Cons(2, MyList.Cons(3, MyList.Nil)))
puts(sum(xs))
