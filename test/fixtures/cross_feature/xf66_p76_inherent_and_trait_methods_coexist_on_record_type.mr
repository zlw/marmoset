# XF66: P76: Inherent and trait methods coexist on record type
type Point = { x: Int, y: Int }
trait Describable[a] = {
  fn describe(x: a) -> Str
}
impl Describable[Point] = {
  fn describe(p: Point) -> Str = "hello"
}
impl Point = {
  fn sum(p: Point) -> Int = p.x + p.y
}
let p = {x: 10, y: 20}
puts(Describable.describe(p))  # output: hello
puts(Point.sum(p))  # output: 30
