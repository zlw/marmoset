# XF24: E24: Multiple aliases + traits + impls coexist
type Point = { x: Int, y: Int }
type Label = { text: Str }
shape Named = {
  name: Str
}
shape Scored = {
  score: Int
}
impl Show[Point] = {
  fn show(p: Point) -> Str = {
    Show.show(p.x) + "," + Show.show(p.y)
  }
}
fn get_name[t: Named](x: t) -> Str = x.name
fn get_score[t: Scored](x: t) -> Int = x.score
let person = { name: "alice", score: 100, active: true }
puts(get_name(person) + " " + Show.show(get_score(person)))  # output: alice 100
