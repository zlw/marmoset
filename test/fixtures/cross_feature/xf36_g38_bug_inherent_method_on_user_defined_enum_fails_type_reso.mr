# XF36: G38: BUG: Inherent method on user-defined enum fails type resolution
# error: Unknown type constructor: mylist
enum mylist { cons(int, mylist) nil }
impl mylist {
  fn sum(xs: mylist) -> int {
    match xs {
      mylist.cons(h, t): h + t.sum()
      mylist.nil: 0
    }
  }
}
let xs = mylist.cons(1, mylist.cons(2, mylist.cons(3, mylist.nil)))
puts(xs.sum())
