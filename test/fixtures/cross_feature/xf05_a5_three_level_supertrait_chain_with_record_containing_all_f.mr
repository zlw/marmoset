# XF05: A5: Three-level supertrait chain with record containing all fields
trait named {
  name: string
}
trait aged: named {
  age: int
}
trait profiled: aged {
  status: string
}
let p: profiled = { name: "alice", age: 30, status: "active", secret: true }
puts(p.name + " " + p.age.show() + " " + p.status)  # output: alice 30 active
