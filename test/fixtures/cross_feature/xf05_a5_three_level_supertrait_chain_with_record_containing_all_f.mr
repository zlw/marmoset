# XF05: A5: Three-level supertrait chain with record containing all fields
trait Named = {
  name: Str
}
trait Aged: Named = {
  age: Int
}
trait Profiled: Aged = {
  status: Str
}

fn summarize[t: Profiled](p: t) -> Str = {
  p.name + " " + p.age.show() + " " + p.status
}

let p = { name: "alice", age: 30, status: "active", secret: true }
puts(summarize(p))  # output: alice 30 active
