# XF14: C13b: Trait impl match binding may be unused in arm body
type OptionInt = { Some(Int), None }
trait Render[a] = {
  fn render(x: a) -> Str
}
impl Render[OptionInt] = {
  fn render(x: OptionInt) -> Str = {
    match x {
      case OptionInt.Some(n): "found"
      case OptionInt.None: "empty"
    }
  }
}
puts(Render.render(OptionInt.Some(42)))  # output: found
