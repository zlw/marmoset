# XF68: P78: Inherent method with comparison on receiver fields
type Point = { x: Int, y: Int }
impl Point = {
  fn is_first_quadrant(p: Point) -> Bool = {
    if (p.x > 0) {
      p.y > 0
    } else {
      false
    }
  }
}
let p: Point = { x: 5, y: 3 }
puts(p.is_first_quadrant())  # output: true
