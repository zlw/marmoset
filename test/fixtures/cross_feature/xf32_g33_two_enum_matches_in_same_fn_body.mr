# XF32: G33: Two enum matches in same fn body
type Point = { x: Int, y: Int }
enum Status = { Ok, Fail }
enum OptionInt = { Some(Int), None }
fn process(s: Status, v: OptionInt) -> Str = {
  let prefix = match s {
    case Status.Ok: "ok"
    case Status.Fail: "err"
  }
  let suffix = match v {
    case OptionInt.Some(n): ":" + n.show()
    case OptionInt.None: ":none"
  }
  prefix + suffix
}
puts(process(Status.Ok, OptionInt.Some(42)))  # output: ok:42
