# XF70: E70: Generic fn with generic enum parameter annotation
# A function like fn[t](opt: Option[t]) should work — the type param `t`
# inside `Option[t]` resolves to the generic's fresh type variable.
enum Option[a] = { Some(a), None }
fn classify[t](opt: Option[t]) -> Str = {
  match opt {
    case Option.Some(_): "some"
    case Option.None: "none"
    case _: "other"
  }
}
let r = classify(Option.Some(42))
puts(r)  # output: some
