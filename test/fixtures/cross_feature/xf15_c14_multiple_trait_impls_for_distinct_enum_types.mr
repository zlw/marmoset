# XF15: C14: Multiple trait impls for distinct enum types
enum Color = { Red, Green, Blue }
enum Light = { Stop, Ready }
trait Render[a] = {
  fn render(x: a) -> Str
}
impl Render[Color] = {
  fn render(x: Color) -> Str = {
    match x {
      case Color.Red: "red"
      case Color.Green: "green"
      case Color.Blue: "blue"
    }
  }
}
impl Render[Light] = {
  fn render(x: Light) -> Str = {
    match x {
      case Light.Stop: "stop"
      case Light.Ready: "ready"
    }
  }
}
puts(Render.render(Color.Red))  # output: red
puts(Render.render(Light.Ready))  # output: ready
