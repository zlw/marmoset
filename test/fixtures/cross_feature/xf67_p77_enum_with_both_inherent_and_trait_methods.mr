# XF67: P77: Enum with both inherent and trait methods
# output: 42
# output: boxed
enum box { val(int) empty }
impl show for box {
  fn show(b: box) -> string {
    "boxed"
  }
}
impl box {
  fn unwrap(b: box) -> int {
    match b {
      box.val(n): n
      box.empty: 0
    }
  }
}
let b = box.val(42)
puts(b.unwrap())
puts(b.show())
