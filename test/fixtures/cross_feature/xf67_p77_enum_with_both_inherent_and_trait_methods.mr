# XF67: P77: Enum with both inherent and trait methods
enum Box = { Val(Int), Empty }
impl Show[Box] = {
  fn show(b: Box) -> Str = "boxed"
}
impl Box = {
  fn unwrap(b: Box) -> Int = {
    match b {
      case Box.Val(n): n
      case Box.Empty: 0
    }
  }
}
let b = Box.Val(42)
puts(Box.unwrap(b))  # output: 42
puts(Show.show(b))  # output: boxed
