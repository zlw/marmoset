# XF30: G31: Trait-constrained fn + enum + record + match
trait Named = {
  name: Str
}
enum Wrapper = { Some(Int), None }
fn extract_name[t: Named](x: t, w: Wrapper) -> Str = {
  match w {
    case Wrapper.Some(_): x.name
    case Wrapper.None: "unknown"
  }
}
let p = { name: "alice", age: 30 }
puts(extract_name(p, Wrapper.Some(1)))  # output: alice
