# XF16: C15: Show-constrained generic function with enum input
enum Color = { Red, Green, Blue }
impl Show[Color] = {
  fn show(x: Color) -> Str = {
    match x {
      case Color.Red: "red"
      case Color.Green: "green"
      case Color.Blue: "blue"
    }
  }
}
fn display[a: Show](x: a) -> Str = {
  x.show()
}
puts(display(Color.Red))  # output: red
