# XF16: C15: Show-constrained generic function with enum input
# output: red
enum color { red green blue }
impl show for color {
  fn show(x: color) -> string {
    match x {
      color.red: "red"
      color.green: "green"
      color.blue: "blue"
    }
  }
}
let display = fn[a: show](x: a) -> string {
  x.show()
}
puts(display(color.red))
