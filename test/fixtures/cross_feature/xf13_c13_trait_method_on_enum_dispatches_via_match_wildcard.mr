# XF13: C13: Trait method on enum dispatches via match (wildcard)
enum OptionInt = { Some(Int), None }
trait Render[a] = {
  fn render(x: a) -> Str
}
impl Render[OptionInt] = {
  fn render(x: OptionInt) -> Str = {
    match x {
      case OptionInt.Some(_): "found"
      case OptionInt.None: "empty"
    }
  }
}
puts(Render.render(OptionInt.Some(42)))  # output: found
