# XF25: E25: If branches return match results on enums
enum OptionInt = { Some(Int), None }
fn describe(flag: Bool, val: OptionInt) -> Str = {
  if (flag) {
    match val {
      case OptionInt.Some(n): "found: " + n.show()
      case OptionInt.None: "empty"
    }
  } else {
    "skipped"
  }
}
puts(describe(true, OptionInt.Some(42)))  # output: found: 42
