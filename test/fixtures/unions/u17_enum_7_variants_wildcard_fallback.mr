# U17: Enum with 7 variants and wildcard fallback
enum Day = { Mon, Tue, Wed, Thu, Fri, Sat, Sun }
let d = Day.Sun
let kind = match d {
  case Day.Mon: "weekday"
  case Day.Tue: "weekday"
  case Day.Wed: "weekday"
  case Day.Thu: "weekday"
  case Day.Fri: "weekday"
  case _: "weekend"
}
puts(kind)  # output: weekend
