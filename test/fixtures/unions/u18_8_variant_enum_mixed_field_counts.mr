# U18: 8-variant enum with mixed field counts
enum Ast = { Num(Int), Str(Str), Add(Int, Int), Neg(Int), Cond(Bool, Int, Int), Nil, Pair(Int, Int), Triple(Int, Int, Int) }
let x = Ast.Cond(true, 42, 0)
let out = match x {
  case Ast.Num(n): n
  case Ast.Str(_): 0
  case Ast.Add(a, b): a + b
  case Ast.Neg(n): 0 - n
  case Ast.Cond(c, t, f): if (c) { t } else { f }
  case Ast.Nil: 0
  case Ast.Pair(a, b): a + b
  case Ast.Triple(a, b, c): a + b + c
}
puts(out)  # output: 42
