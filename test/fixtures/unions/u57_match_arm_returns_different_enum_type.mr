# U57: Match arm returns different enum type than scrutinee
enum Option[a] = { Some(a), None }
enum Result[a, e] = { Ok(a), Err(e) }
let x = Option.Some(42)
let r: Result[Int, Str] = match x {
  case Option.Some(v): Result.Ok(v)
  case Option.None: Result.Err("missing")
}
let out = match r {
  case Result.Ok(_): "success"
  case Result.Err(e): e
}
puts(out)  # output: success
