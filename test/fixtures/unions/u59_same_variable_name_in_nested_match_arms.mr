# U59: Same variable name in nested match arms
enum Option[a] = { Some(a), None }
let x: Option[Option[Str]] = Option.Some(Option.Some("inner"))
let out = match x {
  case Option.Some(v): match v {
    case Option.Some(v): v
    case Option.None: "none2"
  }
  case Option.None: "none1"
}
puts(out)  # output: inner
