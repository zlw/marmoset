# U77: 4 levels deep nested Option (all in nested match)
type Option[a] = { Some(a), None }
let x: Option[Option[Option[Option[Int]]]] = Option.Some(Option.Some(Option.Some(Option.Some(7))))
let d = match x {
  case Option.Some(a): match a {
    case Option.Some(b): match b {
      case Option.Some(c): match c {
        case Option.Some(v): v
        case Option.None: 0
      }
      case Option.None: 0
    }
    case Option.None: 0
  }
  case Option.None: 0
}
puts(d)  # output: 7
