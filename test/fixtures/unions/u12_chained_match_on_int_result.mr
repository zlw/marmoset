# U12: Match on Int result of prior enum match (chained)
enum Option[a] = { Some(a), None }
let x: Option[Int] = Option.Some(10)
let y: Option[Int] = Option.Some(20)
let a = match x { case Option.Some(v): v case Option.None: 0 }
let b = match y { case Option.Some(v): v case Option.None: 0 }
let sum = a + b
let out = match sum {
  case 30: "yes"
  case _: "no"
}
puts(out)  # output: yes
