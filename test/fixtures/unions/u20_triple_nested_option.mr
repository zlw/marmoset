# U20: Triple-nested Option: Some(Some(Some(1)))
enum Option[a] = { Some(a), None }
let x: Option[Option[Option[Int]]] = Option.Some(Option.Some(Option.Some(1)))
let out = match x {
  case Option.Some(a): match a {
    case Option.Some(b): match b {
      case Option.Some(c): c
      case Option.None: 0
    }
    case Option.None: 0
  }
  case Option.None: 0
}
puts(out)  # output: 1
