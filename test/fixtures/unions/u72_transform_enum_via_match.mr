# U72: Transform enum via match, return new enum
enum Option[a] = { Some(a), None }
fn double_opt(x: Option[Int]) -> Option[Int] = {
  match x {
    case Option.Some(v): Option.Some(v * 2)
    case Option.None: Option.None()
  }
}
let r = double_opt(Option.Some(42))
let out = match r {
  case Option.Some(v): v
  case Option.None: 0
}
puts(out)  # output: 84
