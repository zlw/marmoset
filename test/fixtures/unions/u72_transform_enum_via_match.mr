# U72: Transform enum via match, return new enum
enum option[a] { some(a) none }
let double_opt = fn(x: option[int]) -> option[int] {
  match x {
    option.some(v): option.some(v * 2)
    option.none: option.none()
  }
}
let r = double_opt(option.some(42))
let out = match r {
  option.some(v): v
  option.none: 0
}
puts(out)  # output: 84
