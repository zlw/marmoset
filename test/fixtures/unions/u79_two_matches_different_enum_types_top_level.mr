# U79: Two matches on different enum types in top-level scope
enum Option[a] = { Some(a), None }
enum Result[a, e] = { Ok(a), Err(e) }
let x = Option.Some(42)
let y: Result[Str, Int] = Result.Ok("hello")
let a = match x { case Option.Some(v): v case Option.None: 0 }
let b = match y { case Result.Ok(v): v case Result.Err(_): "?" }
puts(b)  # output: hello
