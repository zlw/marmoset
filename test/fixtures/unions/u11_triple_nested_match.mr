# U11: Triple-nested match (match inside match arm body)
enum Option[a] = { Some(a), None }
enum Result[a, e] = { Ok(a), Err(e) }
let x: Option[Result[Int, Str]] = Option.Some(Result.Ok(42))
let out = match x {
  case Option.Some(inner): match inner {
    case Result.Ok(v): match v {
      case 42: "inner"
      case _: "other"
    }
    case Result.Err(_): "error"
  }
  case Option.None: "nothing"
}
puts(out)  # output: inner
