# U56: Match arm returns enum value, then matched again
enum Option[a] = { Some(a), None }
let x = Option.Some(99)
let y = match x {
  case Option.Some(v): Option.Some(v)
  case Option.None: Option.None()
}
let out = match y {
  case Option.Some(v): v
  case Option.None: 0
}
puts(out)  # output: 99
