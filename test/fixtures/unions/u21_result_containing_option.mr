# U21: Result containing Option: Ok(Some(5))
type Option[a] = { Some(a), None }
type Result[a, e] = { Ok(a), Err(e) }
let x: Result[Option[Int], Str] = Result.Ok(Option.Some(5))
let out = match x {
  case Result.Ok(inner): match inner {
    case Option.Some(v): v
    case Option.None: 0
  }
  case Result.Err(_): 0
}
puts(out)  # output: 5
