# U63: Recursive function with enum match
enum Option[a] = { Some(a), None }
fn sum_options(arr: List[Option[Int]], idx: Int, acc: Int) -> Int = {
  if (idx >= len(arr)) {
    acc
  } else {
    let val = match arr[idx] {
      case Option.Some(v): v
      case Option.None: 0
    }
    sum_options(arr, idx + 1, acc + val)
  }
}
let arr = [Option.Some(1), Option.None(), Option.Some(2), Option.Some(3)]
puts(sum_options(arr, 0, 0))  # output: 6
