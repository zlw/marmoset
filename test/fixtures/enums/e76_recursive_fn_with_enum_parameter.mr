# E76: Recursive function with enum parameter
# output: 120
enum option[a] { some(a) none }
let fact = fn(n: int) -> int {
  if (n <= 1) { 1 } else { n * fact(n - 1) }
}
let safe_fact = fn(x: option[int]) -> int {
  match x {
    option.some(n): fact(n)
    option.none: 0
  }
}
puts(safe_fact(option.some(5)))
