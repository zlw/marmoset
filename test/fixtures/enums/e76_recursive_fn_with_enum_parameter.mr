# E76: Recursive function with enum parameter
enum Option[a] = { Some(a), None }
fn fact(n: Int) -> Int = {
  if (n <= 1) { 1 } else { n * fact(n - 1) }
}
fn safe_fact(x: Option[Int]) -> Int = {
  match x {
    case Option.Some(n): fact(n)
    case Option.None: 0
  }
}
puts(safe_fact(Option.Some(5)))  # output: 120
