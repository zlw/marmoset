# E92: Enum match function called multiple times
enum Option[a] = { Some(a), None }
fn unwrap(x: Option[Int], fallback: Int) -> Int = {
  match x {
    case Option.Some(v): v
    case Option.None: fallback
  }
}
let a = unwrap(Option.Some(1), 0)
let b = unwrap(Option.Some(2), 0)
let c = unwrap(Option.None, 99)
puts(a + b + c - 99)  # output: 3
