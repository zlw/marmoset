# E85: Enum value passed through chain of functions
enum Option[a] = { Some(a), None }
fn id(x: Option[Int]) -> Option[Int] = x
fn wrap(n: Int) -> Option[Int] = Option.Some(n)
fn unwrap(x: Option[Int]) -> Int = {
  match x { case Option.Some(v): v case Option.None: 0 }
}
puts(unwrap(id(wrap(42))))  # output: 42
