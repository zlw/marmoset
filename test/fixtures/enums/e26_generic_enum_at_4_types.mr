# E26: Generic enum at 4 types via separate functions
enum Box[a] = { Full(a), Empty }
fn count_int(x: Box[Int]) -> Int = {
  match x { case Box.Full(_): 1 case Box.Empty: 0 }
}
fn count_str(x: Box[Str]) -> Int = {
  match x { case Box.Full(_): 1 case Box.Empty: 0 }
}
fn count_bool(x: Box[Bool]) -> Int = {
  match x { case Box.Full(_): 1 case Box.Empty: 0 }
}
fn count_list(x: Box[List[Int]]) -> Int = {
  match x { case Box.Full(_): 1 case Box.Empty: 0 }
}
let a = Box.Full(42)
let b = Box.Full("hello")
let c = Box.Full(true)
let d = Box.Full([1, 2, 3])
puts(count_int(a) + count_str(b) + count_bool(c) + count_list(d))  # output: 4
