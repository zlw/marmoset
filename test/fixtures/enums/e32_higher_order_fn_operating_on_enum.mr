# E32: Higher-order function operating on enum
enum Option[a] = { Some(a), None }
fn map_opt(x: Option[Int], f: (Int) -> Int) -> Option[Int] = {
  match x {
    case Option.Some(v): Option.Some(f(v))
    case Option.None: Option.None
  }
}
fn double(n: Int) -> Int = n * 2
let result = map_opt(Option.Some(49), double)
let out = match result {
  case Option.Some(v): v + 1
  case Option.None: 0
}
puts(out)  # output: 99
