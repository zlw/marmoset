# E42: Two enums matched in separate functions work
enum Fruit = { Apple, Banana, Cherry }
enum Veggie = { Carrot, Broccoli, Spinach }
fn count_fruit(f: Fruit) -> Int = {
  match f { case Fruit.Cherry: 1 case _: 0 }
}
fn count_veggie(v: Veggie) -> Int = {
  match v { case Veggie.Spinach: 2 case _: 0 }
}
puts(count_fruit(Fruit.Cherry) + count_veggie(Veggie.Spinach))  # output: 3
