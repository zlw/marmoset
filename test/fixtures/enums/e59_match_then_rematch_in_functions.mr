# E59: Match-then-rematch works when isolated in functions
enum Option[a] = { Some(a), None }
fn identity(x: Option[Int]) -> Option[Int] = {
  match x {
    case Option.Some(v): Option.Some(v)
    case Option.None: Option.None
  }
}
fn unwrap(x: Option[Int]) -> Int = {
  match x { case Option.Some(v): v case Option.None: 0 }
}
puts(unwrap(identity(Option.Some(99))))  # output: 99
