# E58: Match returns different enum type then re-matched
enum Color = { Red, Green, Blue }
enum Size = { Small, Medium, Large }
let c = Color.Green
let s = match c {
  case Color.Red: Size.Small
  case Color.Green: Size.Medium
  case Color.Blue: Size.Large
}
let out = match s {
  case Size.Small: 3
  case Size.Medium: 7
  case Size.Large: 11
}
puts(out)  # output: 7
