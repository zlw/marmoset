# E19: Enum with 10+ variants - last variant matches
enum planet { mercury venus earth mars jupiter saturn uranus neptune pluto ceres eris }
let classify = fn(p: planet) -> int {
  match p {
    planet.mercury: 1
    planet.venus: 2
    planet.earth: 3
    planet.mars: 4
    planet.jupiter: 5
    planet.saturn: 6
    planet.uranus: 7
    planet.neptune: 8
    planet.pluto: 9
    planet.ceres: 10
    planet.eris: 11
  }
}
puts(classify(planet.eris))  # output: 11
