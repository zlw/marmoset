# E18: Enum with 10+ variants - middle variant
enum Planet = { Mercury, Venus, Earth, Mars, Jupiter, Saturn, Uranus, Neptune, Pluto, Ceres, Eris }
fn classify(p: Planet) -> Int = {
  match p {
    case Planet.Mercury: 1
    case Planet.Venus: 2
    case Planet.Earth: 3
    case Planet.Mars: 4
    case Planet.Jupiter: 5
    case Planet.Saturn: 6
    case Planet.Uranus: 7
    case Planet.Neptune: 8
    case Planet.Pluto: 9
    case Planet.Ceres: 10
    case Planet.Eris: 11
  }
}
puts(classify(Planet.Jupiter))  # output: 5
