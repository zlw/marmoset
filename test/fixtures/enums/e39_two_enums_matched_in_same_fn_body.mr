# E39: Two enums matched in same function body
enum Color = { Red, Green, Blue }
enum Shape = { Circle, Square, Triangle }
fn describe(c: Color, s: Shape) -> Int = {
  let cv = match c { case Color.Red: 1 case _: 0 }
  let sv = match s { case Shape.Circle: 1 case _: 0 }
  cv * sv
}
puts(describe(Color.Red, Shape.Circle))  # output: 1
