# E84: Match inside match arm body
enum Color = { Red, Green, Blue }
enum Size = { Small, Large }
let c = Color.Green
let s = Size.Small
let out = match c {
  case Color.Red: "Red"
  case Color.Green: match s {
    case Size.Small: "deep"
    case Size.Large: "wide"
  }
  case Color.Blue: "Blue"
}
puts(out)  # output: deep
