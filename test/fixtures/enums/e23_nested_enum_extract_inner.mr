# E23: Enum with another enum as payload - extract Inner
enum Inner = { A(Int), B }
enum Outer = { Wrap(Inner), Empty }
let x = Outer.Wrap(Inner.A(42))
let result = match x {
  case Outer.Wrap(i): match i {
    case Inner.A(n): n
    case Inner.B: 0
  }
  case Outer.Empty: 0
}
puts(result)  # output: 42
