# E47: Enum variant with match-expression as payload
enum Option[a] = { Some(a), None }
enum Color = { Red, Green, Blue }
let c = Color.Green
let x = Option.Some(match c { case Color.Red: 5 case Color.Green: 7 case Color.Blue: 9 })
let result = match x {
  case Option.Some(v): v
  case Option.None: 0
}
puts(result)  # output: 7
