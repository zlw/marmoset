# E99: Enum compatibility sugar supports recursive payloads in Go codegen
enum List = { Nil, Cons(Int, List) }

fn sum(xs: List) -> Int = match xs {
  case List.Nil: 0
  case List.Cons(head, tail): head + sum(tail)
}

let xs = List.Cons(1, List.Cons(2, List.Cons(3, List.Nil)))
puts(sum(xs))  # output: 6
