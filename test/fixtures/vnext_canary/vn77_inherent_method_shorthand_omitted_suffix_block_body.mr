# VN77: Inherent methods compose shape shorthand, omitted suffixes, and block bodies
shape Named = { name: Str }

type Formatter = { prefix: Str }

impl Formatter = {
  fn label(self: Formatter, other: Named) = {
    let joined = self.prefix + other.name
    joined
  }
}

let fmt: Formatter = {prefix: "hi "}
let monkey = { name: "mia", id: 7 }
puts(fmt.label(monkey))  # output: hi mia
