# VN59: Ampersand shorthand composes three trait constraints
shape Named = { name: Str }
shape Aged = { age: Int }
shape Tagged = { tag: Str }

fn describe(x: Named & Aged & Tagged) -> Str =
  x.name + ":" + Show.show(x.age) + ":" + x.tag

let monkey = { name: "George", age: 7, tag: "alpha", bananas: 3 }
puts(describe(monkey))  # output: George:7:alpha
