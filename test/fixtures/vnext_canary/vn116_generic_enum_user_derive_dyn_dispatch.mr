# VN116: Generic enum user derives package concrete constructors into Dyn objects
fn apply[a, b](x: a, f: (a) -> b) -> b = f(x)

trait Label[a]: Show = {
  fn label(self: a) -> Str = apply(self, Show.show(_))
}

enum Box[t] = {
  Wrap(t),
} derive Show, Label

let value: Dyn[Label] = Box.Wrap(42)
puts(Show.show(value))   # output: Wrap(42)
puts(Label.label(value))  # output: Wrap(42)
