# VN71: Omitted impl binders are inferred through nested impl target type arguments
type Pair[a, b] = { Pair(a, b) }

impl Pair[List[a], List[b]] = {
  fn describe(pair: Pair[List[a], List[b]]) -> Str = match pair {
    case Pair.Pair(_, ys): Show.show(len(ys))
  }
}

puts(Pair.describe(Pair.Pair([1], [10, 20, 30])))  # output: 3
