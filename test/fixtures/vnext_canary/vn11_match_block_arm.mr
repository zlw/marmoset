# VN11: Match arm with block body using case keyword
type Direction = { North, South, East, West }
fn describe(d: Direction) -> Str = match d {
  case Direction.North: { "going north" }
  case Direction.South: { "going south" }
  case Direction.East: { "going east" }
  case Direction.West: { "going west" }
}
puts(describe(Direction.North))  # output: going north
puts(describe(Direction.West))   # output: going west
