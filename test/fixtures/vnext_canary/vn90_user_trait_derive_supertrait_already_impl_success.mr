# VN90: User-trait derive can reuse a separately declared supertrait impl
trait Base[a] = {
  fn base(self: a) -> Str = "base"
}

trait Child[a]: Base = {
  fn child(self: a) -> Str = Base.base(self) + ":child"
}

impl Base[Score] = {}

type Score = Int derive Child
let score: Score = 1
puts(Child.child(score))  # output: base:child
