# VN33: Generic default methods codegen correctly without an explicit impl method body
trait Mapper[a] = {
  fn cast[b](x: a, f: (a) -> b) -> b = {
    let out = f(x)
    out
  }
}

impl Mapper[Int] = {}

puts(Mapper.cast(1, (n: Int) -> Show.show(n)))  # output: 1
puts(Mapper.cast(1, (n: Int) -> n + 1))     # output: 2
