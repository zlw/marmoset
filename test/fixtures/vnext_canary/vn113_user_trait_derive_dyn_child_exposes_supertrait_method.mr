# VN113: Derived child trait Dyn objects expose inherited supertrait methods
trait Base[a] = {
  fn base(self: a) -> Str = "base"
}

trait Child[a]: Base = {
  fn child(self: a) -> Str = Base.base(self) + ":child"
}

type Score = Int derive Child, Base

let score: Score = 1
let value: Dyn[Child] = score
puts(Base.base(value))   # output: base
puts(Child.child(value))  # output: base:child
