# VN40: Trait impl methods may omit their signature suffix and inherit the trait signature
trait Display[a] = {
  fn render(x: a) -> Str
}

type Thing = { v: Int }

impl Display[Thing] = {
  fn render(x) = "thing:" + Show.show(x.v)
}

let thing: Thing = {v: 42}
puts(Display.render(thing))  # output: thing:42
