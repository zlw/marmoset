# VN47: Block-bodied default methods work both overridden and inherited
trait Greeter[a]: Show = {
  fn greet(x: a) -> Str = {
    let prefix = "hello "
    let _ = x
    prefix + "fallback"
  }
}

impl Greeter[Int] = {
  override fn greet(x: Int) -> Str = {
    let prefix = "override "
    prefix + Show.show(x)
  }
}

impl Greeter[Bool] = {}

puts(Greeter.greet(1))     # output: override 1
puts(Greeter.greet(true))  # output: hello fallback
