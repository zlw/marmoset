# VN45: Identifier suffixes work on top-level functions and trait methods
fn ready?(n: Int) -> Bool = n > 0

trait Alarm[a] = {
  fn ring!(x: a) -> Str
}

impl Alarm[Int] = {
  fn ring!(x: Int) -> Str = "alarm:" + Show.show(x)
}

puts(ready?(3))  # output: true
puts(Alarm.ring!(3))  # output: alarm:3
