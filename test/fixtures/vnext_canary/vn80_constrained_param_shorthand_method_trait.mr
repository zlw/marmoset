# VN80: Shorthand constraints may mix shapes and method traits
shape Named = { name: Str }
shape Aged = { age: Int }
trait Tagged[a] = {
  fn tag(x: a) -> Str
}

type User = { name: Str, age: Int, id: Int }

impl Tagged[User] = {
  fn tag(x: User) -> Str = "#" + Show.show(x.id)
}

fn describe(x: Named & Aged & Tagged) -> Str = x.name + ":" + Show.show(x.age) + ":" + Tagged.tag(x)

puts(describe({name: "Ada", age: 42, id: 7}))  # output: Ada:42:#7
