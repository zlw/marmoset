# VN94: Default method chains can call inherited defaults and supertrait methods
trait Describe[a]: Show = {
  fn describe(x: a) -> Str = {
    "value:" + Show.show(x)
  }
}

trait Loud[a]: Describe = {
  fn loud(x: a) -> Str = {
    Describe.describe(x) + "!"
  }
}

impl Describe[Int] = {}
impl Loud[Int] = {}

puts(Loud.loud(7))  # output: value:7!
