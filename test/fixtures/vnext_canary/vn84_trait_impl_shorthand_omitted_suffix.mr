# VN84: Trait impl methods combine shorthand params with omitted signature suffixes
shape Named = { name: Str }
trait Mixer[a] = {
  fn mix(x: a, y: Named) -> Str
}

type User = { name: Str }

impl Mixer[User] = {
  fn mix(x: User, y: Named) = x.name + ":" + y.name
}

puts(Mixer.mix({name: "left"}, { name: "right" }))  # output: left:right
