# VN119: Generic enum derives may return Dyn intersections from default methods
trait Pack[a]: Show & Eq = {
  fn pack(self: a) -> Dyn[Show] & Dyn[Eq] = self
}

enum Option[t] = {
  Some(t)
  None
} derive Show, Eq, Pack

let value = Pack.pack(Option.Some(1))
puts(Show.show(value))  # output: Some(1)
