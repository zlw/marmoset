# OP88: Custom num impl drives * operator on enum
enum boxed { val(int) }
impl num for boxed {
  fn add(x: boxed, y: boxed) -> boxed { x }
  fn sub(x: boxed, y: boxed) -> boxed { x }
  fn mul(x: boxed, y: boxed) -> boxed { x }
  fn div(x: boxed, y: boxed) -> boxed { x }
}
let a = boxed.val(42)
let b = boxed.val(99)
match (a * b) {  # output: 42
  boxed.val(n): puts(n)
}
