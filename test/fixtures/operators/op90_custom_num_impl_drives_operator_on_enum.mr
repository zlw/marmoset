# OP90: Custom num impl drives / operator on enum
enum Boxed = { Val(Int) }
impl Num[Boxed] = {
  fn add(x: Boxed, y: Boxed) -> Boxed = x
  fn sub(x: Boxed, y: Boxed) -> Boxed = x
  fn mul(x: Boxed, y: Boxed) -> Boxed = x
  fn div(x: Boxed, y: Boxed) -> Boxed = y
}
let a = Boxed.Val(7)
let b = Boxed.Val(11)
match (a / b) {  # output: 11
  case Boxed.Val(n): puts(n)
}
