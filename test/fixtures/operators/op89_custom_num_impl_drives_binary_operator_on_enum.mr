# OP89: Custom num impl drives - (binary) operator on enum
enum boxed { val(int) }
impl num for boxed {
  fn add(x: boxed, y: boxed) -> boxed { x }
  fn sub(x: boxed, y: boxed) -> boxed { x }
  fn mul(x: boxed, y: boxed) -> boxed { x }
  fn div(x: boxed, y: boxed) -> boxed { x }
}
let a = boxed.val(7)
let b = boxed.val(3)
match (a - b) {  # output: 7
  boxed.val(n): puts(n)
}
