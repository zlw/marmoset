enum Boxed = { Val(Int) }
impl Num[Boxed] = {
  fn add(x: Boxed, y: Boxed) -> Boxed = x
  fn sub(x: Boxed, y: Boxed) -> Boxed = x
  fn mul(x: Boxed, y: Boxed) -> Boxed = x
  fn div(x: Boxed, y: Boxed) -> Boxed = x
}
puts(3 + 4)  # output: 7
let a = Boxed.Val(100)
let b = Boxed.Val(200)
match (a + b) {
  case Boxed.Val(n): puts(n)  # output: 100
}
