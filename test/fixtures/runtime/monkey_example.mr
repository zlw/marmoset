let name = "Monkey"
let age = 1
let inspirations = ["Scheme", "Lisp", "JavaScript", "Clojure"]
let book = {
  "title": "Writing A Compiler In Go",
  "author": "Thorsten Ball",
  "prequel": "Writing An Interpreter In Go"
}

fn print_book_name(book: Map[Str, Str]) => Unit = {
  let title = book["title"]
  let author = book["author"]

  puts(author + " - " + title)  # output: Thorsten Ball - Writing A Compiler In Go
}
print_book_name(book)

fn fibonacci(x: Int) -> Int = {
  if (x == 0) {
    0
  } else {
    if (x == 1) {
      return 1
    } else {
      fibonacci(x - 1) + fibonacci(x - 2)
    }
  }
}

fn map_list(arr: List[Int], f: (Int) -> Int) -> List[Int] = {
  let iter = (arr: List[Int], accumulated: List[Int]) -> {
    if (len(arr) == 0) {
      accumulated
    } else {
      iter(rest(arr), push(accumulated, f(first(arr))))
    }
  }

  iter(arr, [])
}

let numbers = [1, 1 + 1, 4 - 1, 2 * 2, 2 + 3, 12 / 2]
puts(map_list(numbers, fibonacci))  # output: [1 1 2 3 5 8]
