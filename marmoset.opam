opam-version: "2.0"
synopsis: "Statically typed language compiling to Go"
description:
  "A statically typed language implemented in OCaml with Go code generation"
maintainer: ["Krzysztof Zalewski <zlw.zalewski@gmail.com>"]
authors: ["Krzysztof Zalewski <zlw.zalewski@gmail.com>"]
license: "MIT"
tags: ["language" "compiler" "typechecker" "go"]
homepage: "https://github.com/zlw/marmoset-ml"
